{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrkr.dev/schemas/v1/export/inventory-export.schema.json",
  "title": "Wrkr Inventory Export",
  "type": "object",
  "required": ["export_version", "exported_at", "org", "tools"],
  "properties": {
    "export_version": {"type": "string"},
    "exported_at": {"type": "string", "format": "date-time"},
    "org": {"type": "string"},
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "agent_instance_id", "framework", "org", "repo", "location"],
        "properties": {
          "agent_id": {"type": "string"},
          "agent_instance_id": {"type": "string"},
          "framework": {"type": "string"},
          "org": {"type": "string"},
          "repo": {"type": "string"},
          "location": {"type": "string"},
          "location_range": {
            "type": "object",
            "required": ["start_line", "end_line"],
            "properties": {
              "start_line": {"type": "integer", "minimum": 1},
              "end_line": {"type": "integer", "minimum": 1}
            },
            "additionalProperties": false
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_id", "agent_id", "discovery_method", "tool_type", "org"],
        "properties": {
          "tool_id": {"type": "string"},
          "agent_id": {"type": "string"},
          "discovery_method": {"type": "string", "enum": ["static"]},
          "tool_type": {"type": "string"},
          "org": {"type": "string"}
        }
      }
    }
  }
}
