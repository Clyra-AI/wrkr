{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrkr.dev/schemas/v1/composed-action-path.schema.json",
  "title": "Wrkr Composed Action Path",
  "type": "object",
  "required": ["composition_id", "pattern_id", "pattern", "stages"],
  "properties": {
    "composition_id": {"type": "string"},
    "pattern_id": {"$ref": "#/$defs/patternID"},
    "pattern": {"$ref": "#/$defs/pattern"},
    "resolution_key": {"type": "string"},
    "path_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "workflow_chain_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "stages": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "items": {"$ref": "#/$defs/stage"}
    },
    "transitions": {
      "type": "array",
      "maxItems": 4,
      "items": {"$ref": "#/$defs/transition"}
    },
    "target_identity": {"type": "string"},
    "durable_outcome_key": {"type": "string"},
    "outcome_key": {"type": "string"},
    "affected_asset": {"type": "string"},
    "outcome_class": {"type": "string"},
    "environment": {"type": "string"},
    "target_class": {"$ref": "#/$defs/targetClass"},
    "claim_state": {"$ref": "#/$defs/claimState"},
    "evidence_state": {"$ref": "#/$defs/evidenceState"},
    "freshness_state": {"$ref": "#/$defs/freshnessState"},
    "policy_coverage_status": {"$ref": "#/$defs/policyCoverageStatus"},
    "gait_coverage": {"type": "object", "additionalProperties": true},
    "runtime_evidence_absence_status": {"type": "string"},
    "contradictions": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": true}
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "proof_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source_decision_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "risk_tier": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
    "recommended_control": {"type": "string"},
    "recommended_control_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "escalating_transition_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "most_restrictive_source": {"type": "string"},
    "closure_requirements": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": true}
    },
    "evidence_completeness": {"type": "object", "additionalProperties": true},
    "unsupported_surfaces": {
      "type": "array",
      "items": {"type": "string"}
    },
    "truncated_candidates": {
      "type": "array",
      "items": {"type": "string"}
    },
    "proposed_action_contract": {
      "oneOf": [
        {"$ref": "proposed-action-contract.schema.json"},
        {"$ref": "proposed-action-contract-v3.schema.json"}
      ]
    },
    "proposed_action_contract_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "equivalent_outcome_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "equivalent_outcome_escalation_source": {"type": "string"},
    "approval_evasion_signal": {
      "type": "string",
      "enum": ["none", "possible", "unknown"]
    },
    "coverage_delta_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "materiality": {
      "type": "string",
      "enum": ["none", "low", "material"]
    },
    "reachability_state": {"$ref": "#/$defs/reachabilityState"},
    "observed_execution": {"type": "boolean"},
    "alternate_route_refs": {
      "type": "array",
      "maxItems": 8,
      "items": {"type": "string"}
    },
    "truncations": {
      "type": "array",
      "maxItems": 8,
      "items": {"$ref": "#/$defs/truncation"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "pattern": {
      "type": "object",
      "required": ["pattern_id"],
      "properties": {
        "pattern_id": {"$ref": "#/$defs/patternID"},
        "description": {"type": "string"},
        "stage_roles": {
          "type": "array",
          "maxItems": 5,
          "items": {"$ref": "#/$defs/stageRole"}
        },
        "outcome_class": {"type": "string"},
        "min_stages": {"type": "integer", "minimum": 2, "maximum": 5},
        "max_stages": {"type": "integer", "minimum": 2, "maximum": 5},
        "stage_templates": {
          "type": "array",
          "maxItems": 3,
          "items": {"$ref": "#/$defs/stageTemplate"}
        },
        "required_transition_evidence": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string"}
        },
        "trust_boundary_constraint": {"type": "string", "maxLength": 180}
      },
      "additionalProperties": false
    },
    "stage": {
      "type": "object",
      "required": ["stage_id", "role"],
      "properties": {
        "stage_id": {"type": "string"},
        "role": {"$ref": "#/$defs/stageRole"},
        "path_id": {"type": "string"},
        "resolution_key": {"type": "string"},
        "tool_type": {"type": "string"},
        "location": {"type": "string"},
        "action_classes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "target_class": {"$ref": "#/$defs/targetClass"},
        "evidence_state": {"$ref": "#/$defs/evidenceState"},
        "freshness_state": {"$ref": "#/$defs/freshnessState"},
        "policy_coverage_status": {"$ref": "#/$defs/policyCoverageStatus"},
        "gait_coverage": {"type": "object", "additionalProperties": true},
        "runtime_evidence_absence_status": {"type": "string"},
        "contradictions": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        },
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "proof_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "source_decision_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "relationship": {"$ref": "#/$defs/delegationRelationship"},
        "parent_authority_ref": {"type": "string"},
        "child_authority_ref": {"type": "string"},
        "scope_delta": {
          "type": "array",
          "items": {"type": "string"}
        },
        "target_delta": {
          "type": "array",
          "items": {"type": "string"}
        },
        "credential_delta": {
          "type": "array",
          "items": {"type": "string"}
        },
        "expiry_delta": {
          "type": "array",
          "items": {"type": "string"}
        },
        "reason_codes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "system_class": {"$ref": "#/$defs/systemClass"},
        "trust_boundary": {"type": "string", "maxLength": 180},
        "correlation_refs": {
          "type": "array",
          "maxItems": 16,
          "items": {"type": "string", "maxLength": 512}
        },
        "alternate_route_refs": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string"}
        },
        "reachability_state": {"$ref": "#/$defs/reachabilityState"},
        "observed_execution": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "transition": {
      "type": "object",
      "required": ["transition_id", "from_stage_id", "to_stage_id"],
      "properties": {
        "transition_id": {"type": "string"},
        "from_stage_id": {"type": "string"},
        "to_stage_id": {"type": "string"},
        "claim_state": {"$ref": "#/$defs/claimState"},
        "evidence_state": {"$ref": "#/$defs/evidenceState"},
        "policy_coverage_status": {"$ref": "#/$defs/policyCoverageStatus"},
        "gait_coverage": {"type": "object", "additionalProperties": true},
        "runtime_evidence_absence_status": {"type": "string"},
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "proof_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "source_decision_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "reason_codes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "relationship": {"$ref": "#/$defs/delegationRelationship"},
        "parent_authority_ref": {"type": "string"},
        "child_authority_ref": {"type": "string"},
        "scope_delta": {
          "type": "array",
          "items": {"type": "string"}
        },
        "target_delta": {
          "type": "array",
          "items": {"type": "string"}
        },
        "credential_delta": {
          "type": "array",
          "items": {"type": "string"}
        },
        "expiry_delta": {
          "type": "array",
          "items": {"type": "string"}
        },
        "from_system_class": {"$ref": "#/$defs/systemClass"},
        "to_system_class": {"$ref": "#/$defs/systemClass"},
        "trust_boundary": {"type": "string", "maxLength": 362},
        "correlation_refs": {
          "type": "array",
          "maxItems": 16,
          "items": {"type": "string", "maxLength": 512}
        },
        "alternate_route_refs": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string"}
        },
        "freshness_state": {"$ref": "#/$defs/freshnessState"},
        "reachability_state": {"$ref": "#/$defs/reachabilityState"},
        "observed_execution": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "stageRole": {
      "type": "string",
      "enum": ["source", "transform", "sink", "internal_sink", "external_sink", "privileged_sink", "destructive_sink"]
    },
    "patternID": {
      "type": "string",
      "enum": ["sensitive_read_to_egress", "secret_to_network", "code_to_deploy", "workflow_mutation_to_production", "package_change_to_release", "sensitive_read_to_egress_multistage", "secret_to_network_multistage", "code_to_deploy_multistage", "workflow_mutation_to_production_multistage", "package_change_to_release_multistage"]
    },
    "stageTemplate": {
      "type": "object",
      "required": ["role", "allowed_system_classes"],
      "properties": {
        "role": {"$ref": "#/$defs/stageRole"},
        "allowed_system_classes": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/systemClass"}
        }
      },
      "additionalProperties": false
    },
    "systemClass": {
      "type": "string",
      "enum": ["repo", "ci", "package", "cloud", "saas", "communications", "unknown"]
    },
    "reachabilityState": {
      "type": "string",
      "enum": ["possible", "incomplete", "observed"]
    },
    "truncation": {
      "type": "object",
      "required": ["pattern_id", "reason", "limit"],
      "properties": {
        "pattern_id": {"$ref": "#/$defs/patternID"},
        "reason": {"type": "string", "enum": ["depth_cap", "path_cap", "candidate_cap", "reference_cap"]},
        "limit": {"type": "integer", "minimum": 1},
        "observed_candidates": {"type": "integer", "minimum": 0},
        "omitted_candidates": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "claimState": {
      "type": "string",
      "enum": ["static_only", "partially_evidenced", "declared_policy_only", "runtime_controlled", "observed_execution", "contradictory", "unknown"]
    },
    "delegationRelationship": {
      "type": "string",
      "enum": ["narrowed", "equal", "broadened", "unknown", "contradictory"]
    },
    "evidenceState": {
      "type": "string",
      "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]
    },
    "freshnessState": {
      "type": "string",
      "enum": ["fresh", "stale", "expired", "unknown"]
    },
    "policyCoverageStatus": {
      "type": "string",
      "enum": ["none", "declared", "matched", "runtime_proven", "stale", "conflict"]
    },
    "targetClass": {
      "type": "string",
      "enum": ["production_impacting", "release_adjacent", "customer_data_adjacent", "internal_tooling", "developer_productivity", "test_demo_sandbox", "unknown"]
    }
  }
}
