{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrkr.dev/schemas/v1/control-path-graph.schema.json",
  "title": "Wrkr Control Path Graph",
  "type": "object",
  "required": ["version", "summary", "nodes", "edges"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1"]
    },
    "summary": {
      "type": "object",
      "required": ["total_nodes", "total_edges", "node_kinds", "edge_kinds"],
      "properties": {
        "total_nodes": {"type": "integer", "minimum": 0},
        "total_edges": {"type": "integer", "minimum": 0},
        "node_kinds": {
          "type": "array",
          "items": {"$ref": "#/$defs/kindRollup"}
        },
        "edge_kinds": {
          "type": "array",
          "items": {"$ref": "#/$defs/kindRollup"}
        }
      },
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "items": {"$ref": "#/$defs/node"}
    },
    "edges": {
      "type": "array",
      "items": {"$ref": "#/$defs/edge"}
    }
  },
  "$defs": {
    "kindRollup": {
      "type": "object",
      "required": ["kind", "count"],
      "properties": {
        "kind": {"type": "string"},
        "count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": ["node_id", "path_id", "kind", "org", "repo"],
      "properties": {
        "node_id": {"type": "string"},
        "path_id": {"type": "string"},
        "kind": {
          "type": "string",
          "enum": [
            "control_path",
            "agent",
            "execution_identity",
            "credential",
            "tool",
            "workflow",
            "repo",
            "governance_control",
            "target",
            "action_capability"
          ]
        },
        "lineage_segment": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "label": {"type": "string"},
        "tool_type": {"type": "string"},
        "location": {"type": "string"},
        "agent_id": {"type": "string"},
        "purpose": {"type": "string"},
        "purpose_source": {"type": "string"},
        "purpose_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "version": {"type": "string"},
        "version_source": {"type": "string"},
        "config_fingerprint": {"type": "string"},
        "config_source": {"type": "string"},
        "status": {"type": "string"},
        "credential_authority": {"$ref": "#/$defs/credentialAuthority"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "source_refs": {"type": "array", "items": {"type": "string"}},
        "attack_path_refs": {"type": "array", "items": {"type": "string"}},
        "source_finding_keys": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["edge_id", "path_id", "kind", "from_node_id", "to_node_id"],
      "properties": {
        "edge_id": {"type": "string"},
        "path_id": {"type": "string"},
        "kind": {"type": "string"},
        "from_node_id": {"type": "string"},
        "to_node_id": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "source_refs": {"type": "array", "items": {"type": "string"}},
        "attack_path_refs": {"type": "array", "items": {"type": "string"}},
        "source_finding_keys": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "credentialAuthority": {
      "type": "object",
      "required": ["credential_present", "credential_referenced_by_workflow", "credential_usable_by_path", "standing_access", "likely_jit"],
      "properties": {
        "credential_present": {"type": "boolean"},
        "credential_referenced_by_workflow": {"type": "boolean"},
        "credential_usable_by_path": {"type": "boolean"},
        "credential_kind": {"type": "string", "enum": ["github_pat", "github_workflow_token", "github_app_key", "deploy_key", "cloud_admin_key", "cloud_access_key", "oidc_workload_identity", "delegated_oauth", "jit_credential", "inherited_human", "static_secret", "unknown_durable", "unknown"]},
        "access_type": {"type": "string", "enum": ["standing", "jit", "delegated", "workload", "inherited", "unknown"]},
        "standing_access": {"type": "boolean"},
        "likely_jit": {"type": "boolean"},
        "rotation_evidence_status": {"type": "string", "enum": ["present", "missing", "not_applicable", "unknown", "stale"]},
        "credential_source": {"type": "string", "enum": ["workflow_secret_ref", "workflow_builtin_token", "non_human_identity", "auth_surface", "detector_evidence", "direct_config", "unknown"]},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
