{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrkr.dev/schemas/v1/inventory/inventory.schema.json",
  "title": "Wrkr Inventory",
  "type": "object",
  "required": ["inventory_version", "generated_at", "org", "agents", "tools", "methodology", "approval_summary", "adoption_summary", "regulatory_summary", "privilege_budget", "agent_privilege_map", "summary"],
  "properties": {
    "inventory_version": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "org": {"type": "string"},
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "agent_instance_id", "framework", "org", "repo", "location"],
        "properties": {
          "agent_id": {"type": "string"},
          "agent_instance_id": {"type": "string"},
          "framework": {"type": "string"},
          "org": {"type": "string"},
          "repo": {"type": "string"},
          "location": {"type": "string"},
          "location_range": {
            "type": "object",
            "required": ["start_line", "end_line"],
            "properties": {
              "start_line": {"type": "integer", "minimum": 1},
              "end_line": {"type": "integer", "minimum": 1}
            },
            "additionalProperties": false
          },
          "bound_tools": {"type": "array", "items": {"type": "string"}},
          "bound_data_sources": {"type": "array", "items": {"type": "string"}},
          "bound_auth_surfaces": {"type": "array", "items": {"type": "string"}},
          "binding_evidence_keys": {"type": "array", "items": {"type": "string"}},
          "missing_bindings": {"type": "array", "items": {"type": "string"}},
          "deployment_status": {"type": "string", "enum": ["unknown", "deployed", "ambiguous"]},
          "deployment_artifacts": {"type": "array", "items": {"type": "string"}},
          "deployment_evidence_keys": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_id", "agent_id", "discovery_method", "tool_type", "tool_category", "confidence_score", "org", "repos", "locations", "permission_surface", "permission_tier", "risk_tier", "adoption_pattern", "regulatory_mapping", "endpoint_class", "data_class", "autonomy_level", "risk_score", "approval_status", "approval_classification", "lifecycle_state"],
        "properties": {
          "tool_id": {"type": "string"},
          "agent_id": {"type": "string"},
          "discovery_method": {"type": "string", "enum": ["static"]},
          "tool_type": {"type": "string"},
          "tool_category": {
            "type": "string",
            "enum": [
              "assistant",
              "agent_framework",
              "mcp_integration",
              "plugin_extension",
              "model_api_integration",
              "custom_wrapper"
            ]
          },
          "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
          "org": {"type": "string"},
          "repos": {"type": "array", "items": {"type": "string"}},
          "locations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["repo", "location", "owner"],
              "properties": {
                "repo": {"type": "string"},
                "location": {"type": "string"},
                "owner": {"type": "string"},
                "owner_source": {"type": "string", "enum": ["codeowners", "custom_owner_mapping", "service_catalog", "backstage_catalog", "github_metadata", "repo_fallback", "multi_repo_conflict", "missing_owner"]},
                "ownership_status": {"type": "string", "enum": ["explicit", "inferred", "unresolved"]},
                "ownership_state": {"type": "string", "enum": ["explicit_owner", "inferred_owner", "conflicting_owner", "missing_owner"]},
                "ownership_confidence": {"type": "number", "minimum": 0, "maximum": 1},
                "ownership_evidence_basis": {"type": "array", "items": {"type": "string"}},
                "ownership_conflicts": {"type": "array", "items": {"type": "string"}}
              }
            }
          },
          "permissions": {"type": "array", "items": {"type": "string"}},
          "permission_surface": {
            "type": "object",
            "required": ["read", "write", "admin"],
            "properties": {
              "read": {"type": "boolean"},
              "write": {"type": "boolean"},
              "admin": {"type": "boolean"}
            }
          },
          "permission_tier": {"type": "string", "enum": ["none", "read", "write", "admin"]},
          "risk_tier": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
          "adoption_pattern": {"type": "string", "enum": ["org_wide", "team_level", "individual", "one_off"]},
          "regulatory_mapping": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["regulation", "control_id", "status", "rationale"],
              "properties": {
                "regulation": {"type": "string"},
                "control_id": {"type": "string"},
                "status": {"type": "string", "enum": ["pass", "gap", "unknown"]},
                "rationale": {"type": "string"}
              }
            }
          },
          "endpoint_class": {"type": "string"},
          "data_class": {"type": "string"},
          "autonomy_level": {"type": "string"},
          "risk_score": {"type": "number"},
          "approval_status": {"type": "string"},
          "approval_classification": {"type": "string", "enum": ["approved", "unapproved", "unknown"]},
          "lifecycle_state": {"type": "string", "enum": ["discovered", "under_review", "approved", "active", "deprecated", "revoked"]},
          "trust_depth": {"$ref": "#/$defs/trustDepth"}
        }
      }
    },
    "non_human_identities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["identity_id", "identity_type", "subject", "source", "org", "repo", "location"],
        "properties": {
          "identity_id": {"type": "string"},
          "identity_type": {"type": "string", "enum": ["github_app", "bot_user", "service_account", "unknown"]},
          "subject": {"type": "string"},
          "source": {"type": "string"},
          "org": {"type": "string"},
          "repo": {"type": "string"},
          "location": {"type": "string"},
          "confidence": {"type": "string", "enum": ["high", "low"]}
        }
      }
    },
    "methodology": {
      "type": "object",
      "required": ["wrkr_version", "scan_started_at", "scan_completed_at", "scan_duration_seconds", "repo_count", "file_count_processed", "detectors"],
      "properties": {
        "wrkr_version": {"type": "string"},
        "scan_started_at": {"type": "string"},
        "scan_completed_at": {"type": "string"},
        "scan_duration_seconds": {"type": "number"},
        "repo_count": {"type": "integer"},
        "file_count_processed": {"type": "integer"},
        "detectors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "version", "finding_count"],
            "properties": {
              "id": {"type": "string"},
              "version": {"type": "string"},
              "finding_count": {"type": "integer"}
            }
          }
        }
      }
    },
    "approval_summary": {
      "type": "object",
      "required": [
        "approved_tools",
        "unapproved_tools",
        "unknown_tools",
        "approved_percent",
        "unapproved_percent",
        "unknown_percent",
        "unapproved_per_approved"
      ],
      "properties": {
        "approved_tools": {"type": "integer"},
        "unapproved_tools": {"type": "integer"},
        "unknown_tools": {"type": "integer"},
        "approved_percent": {"type": "number"},
        "unapproved_percent": {"type": "number"},
        "unknown_percent": {"type": "number"},
        "unapproved_per_approved": {"type": ["number", "null"]}
      }
    },
    "adoption_summary": {
      "type": "object",
      "required": ["org_wide", "team_level", "individual", "one_off"],
      "properties": {
        "org_wide": {"type": "integer"},
        "team_level": {"type": "integer"},
        "individual": {"type": "integer"},
        "one_off": {"type": "integer"}
      }
    },
    "regulatory_summary": {
      "type": "object",
      "required": ["by_regulation", "by_control"],
      "properties": {
        "by_regulation": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["regulation", "total", "pass", "gap", "unknown"],
            "properties": {
              "regulation": {"type": "string"},
              "total": {"type": "integer"},
              "pass": {"type": "integer"},
              "gap": {"type": "integer"},
              "unknown": {"type": "integer"}
            }
          }
        },
        "by_control": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["regulation", "control_id", "total", "pass", "gap", "unknown"],
            "properties": {
              "regulation": {"type": "string"},
              "control_id": {"type": "string"},
              "total": {"type": "integer"},
              "pass": {"type": "integer"},
              "gap": {"type": "integer"},
              "unknown": {"type": "integer"}
            }
          }
        }
      }
    },
    "repo_exposure_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["org", "repo", "permission_union", "data_union", "highest_autonomy", "combined_risk_score", "skill_privilege_ceiling", "skill_privilege_concentration", "skill_sprawl"],
        "properties": {
          "org": {"type": "string"},
          "repo": {"type": "string"},
          "permission_union": {"type": "array", "items": {"type": "string"}},
          "data_union": {"type": "array", "items": {"type": "string"}},
          "highest_autonomy": {"type": "string"},
          "combined_risk_score": {"type": "number"},
          "skill_privilege_ceiling": {"type": "array", "items": {"type": "string"}},
          "skill_privilege_concentration": {
            "type": "object",
            "required": ["exec_ratio", "write_ratio", "exec_write_ratio"],
            "properties": {
              "exec_ratio": {"type": "number"},
              "write_ratio": {"type": "number"},
              "exec_write_ratio": {"type": "number"}
            }
          },
          "skill_sprawl": {
            "type": "object",
            "required": ["total", "exec", "write", "read", "none"],
            "properties": {
              "total": {"type": "integer"},
              "exec": {"type": "integer"},
              "write": {"type": "integer"},
              "read": {"type": "integer"},
              "none": {"type": "integer"}
            }
          }
        }
      }
    },
    "local_governance": {
      "type": "object",
      "required": ["reference_basis", "status", "sanctioned_tools", "unsanctioned_tools", "unknown_tools"],
      "properties": {
        "reference_basis": {"type": "string", "enum": ["approved_tools_policy", "unavailable"]},
        "reference_path": {"type": "string"},
        "status": {"type": "string", "enum": ["configured", "unavailable"]},
        "sanctioned_tools": {"type": "integer"},
        "unsanctioned_tools": {"type": "integer"},
        "unknown_tools": {"type": "integer"}
      }
    },
    "privilege_budget": {
      "type": "object",
      "required": ["total_tools", "write_capable_tools", "credential_access_tools", "exec_capable_tools", "production_write"],
      "properties": {
        "total_tools": {"type": "integer"},
        "write_capable_tools": {"type": "integer"},
        "credential_access_tools": {"type": "integer"},
        "exec_capable_tools": {"type": "integer"},
        "production_write": {
          "type": "object",
          "required": ["configured", "status", "count"],
          "properties": {
            "configured": {"type": "boolean"},
            "status": {"type": "string", "enum": ["configured", "not_configured", "invalid"]},
            "count": {"type": ["integer", "null"]}
          }
        }
      }
    },
    "agent_privilege_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "agent_id",
          "tool_id",
          "tool_type",
          "org",
          "repos",
          "permissions",
          "endpoint_class",
          "data_class",
          "autonomy_level",
          "risk_score",
          "write_capable",
          "credential_access",
          "exec_capable",
          "production_write"
        ],
        "properties": {
          "agent_id": {"type": "string"},
          "tool_id": {"type": "string"},
          "tool_type": {"type": "string"},
          "framework": {"type": "string"},
          "org": {"type": "string"},
          "repos": {"type": "array", "items": {"type": "string"}},
          "permissions": {"type": "array", "items": {"type": "string"}},
          "action_classes": {"type": "array", "items": {"type": "string"}},
          "action_reasons": {"type": "array", "items": {"type": "string"}},
          "endpoint_class": {"type": "string"},
          "data_class": {"type": "string"},
          "autonomy_level": {"type": "string"},
          "risk_score": {"type": "number"},
          "approval_classification": {"type": "string", "enum": ["approved", "unapproved", "unknown"]},
          "bound_tools": {"type": "array", "items": {"type": "string"}},
          "bound_data_sources": {"type": "array", "items": {"type": "string"}},
          "bound_auth_surfaces": {"type": "array", "items": {"type": "string"}},
          "binding_evidence_keys": {"type": "array", "items": {"type": "string"}},
          "missing_bindings": {"type": "array", "items": {"type": "string"}},
          "deployment_status": {"type": "string", "enum": ["unknown", "deployed", "ambiguous"]},
          "deployment_artifacts": {"type": "array", "items": {"type": "string"}},
          "deployment_evidence_keys": {"type": "array", "items": {"type": "string"}},
          "operational_owner": {"type": "string"},
          "owner_source": {"type": "string", "enum": ["codeowners", "custom_owner_mapping", "service_catalog", "backstage_catalog", "github_metadata", "repo_fallback", "multi_repo_conflict", "missing_owner"]},
          "ownership_status": {"type": "string", "enum": ["explicit", "inferred", "unresolved"]},
          "ownership_state": {"type": "string", "enum": ["explicit_owner", "inferred_owner", "conflicting_owner", "missing_owner"]},
          "ownership_confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "ownership_evidence_basis": {"type": "array", "items": {"type": "string"}},
          "ownership_conflicts": {"type": "array", "items": {"type": "string"}},
          "approval_gap_reasons": {"type": "array", "items": {"type": "string"}},
          "trust_depth": {"$ref": "#/$defs/trustDepth"},
          "pull_request_write": {"type": "boolean"},
          "merge_execute": {"type": "boolean"},
          "deploy_write": {"type": "boolean"},
          "delivery_chain_status": {"type": "string", "enum": ["none", "pr_only", "merge_only", "deploy_only", "pr_merge", "merge_deploy", "pr_merge_deploy"]},
          "production_target_status": {"type": "string", "enum": ["configured", "not_configured", "invalid"]},
          "write_capable": {"type": "boolean"},
          "credential_access": {"type": "boolean"},
          "credential_provenance": {
            "type": "object",
            "required": ["type", "scope", "confidence", "risk_multiplier"],
            "properties": {
              "type": {"type": "string", "enum": ["static_secret", "workload_identity", "inherited_human", "oauth_delegation", "jit", "unknown"]},
              "subject": {"type": "string"},
              "scope": {"type": "string", "enum": ["repository", "workflow", "tool", "environment", "organization", "unknown"]},
              "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
              "evidence_basis": {"type": "array", "items": {"type": "string"}},
              "credential_kind": {"type": "string", "enum": ["github_pat", "github_app_key", "deploy_key", "cloud_admin_key", "cloud_access_key", "oidc_workload_identity", "delegated_oauth", "jit_credential", "inherited_human", "static_secret", "unknown_durable", "unknown"]},
              "access_type": {"type": "string", "enum": ["standing", "jit", "delegated", "workload", "inherited", "unknown"]},
              "standing_access": {"type": "boolean"},
              "likely_jit": {"type": "boolean"},
              "evidence_location": {"type": "string"},
              "classification_reasons": {"type": "array", "items": {"type": "string"}},
              "risk_multiplier": {"type": "number"}
            },
            "additionalProperties": false
          },
          "standing_privilege": {"type": "boolean"},
          "standing_privilege_reasons": {"type": "array", "items": {"type": "string"}},
          "exec_capable": {"type": "boolean"},
          "production_write": {"type": "boolean"},
          "matched_production_targets": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_tools", "high_risk", "medium_risk", "low_risk"],
      "properties": {
        "total_tools": {"type": "integer"},
        "high_risk": {"type": "integer"},
        "medium_risk": {"type": "integer"},
        "low_risk": {"type": "integer"}
      }
    }
  },
  "$defs": {
    "trustDepth": {
      "type": "object",
      "required": ["auth_strength", "delegation_model", "exposure", "policy_binding", "gateway_binding", "gateway_coverage", "trust_depth_score"],
      "properties": {
        "surface": {"type": "string", "enum": ["mcp", "a2a"]},
        "auth_strength": {"type": "string", "enum": ["none", "static_secret", "workload_identity", "inherited_human", "oauth_delegation", "jit", "unknown"]},
        "delegation_model": {"type": "string", "enum": ["none", "tool_proxy", "agent_delegate", "unknown"]},
        "exposure": {"type": "string", "enum": ["local", "private", "public", "unknown"]},
        "policy_binding": {"type": "string", "enum": ["declared", "missing"]},
        "policy_refs": {"type": "array", "items": {"type": "string"}},
        "gateway_binding": {"type": "string", "enum": ["bound", "unbound", "unknown"]},
        "gateway_coverage": {"type": "string", "enum": ["protected", "unprotected", "unknown"]},
        "sanitization_claims": {"type": "array", "items": {"type": "string"}},
        "capability_exposure": {"type": "array", "items": {"type": "string"}},
        "trust_gaps": {"type": "array", "items": {"type": "string"}},
        "trust_depth_score": {"type": "number"}
      },
      "additionalProperties": false
    }
  }
}
