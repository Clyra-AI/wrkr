{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.clyra.ai/wrkr/v1/report/report-summary.schema.json",
  "title": "Wrkr Report Summary",
  "type": "object",
  "required": [
    "summary_version",
    "generated_at",
    "template",
    "share_profile",
    "section_order",
    "sections",
    "headline",
    "methodology",
    "top_risks",
    "privilege_budget",
    "deltas",
    "lifecycle",
    "proof",
    "next_actions"
  ],
  "properties": {
    "summary_version": {
      "type": "string",
      "enum": ["v1"]
    },
    "generated_at": {
      "type": "string"
    },
    "template": {
      "type": "string",
      "enum": ["exec", "operator", "audit", "public", "ciso", "appsec", "platform", "customer-draft"]
    },
    "share_profile": {
      "type": "string",
      "enum": ["internal", "public"]
    },
    "section_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "headline": {
      "$ref": "#/$defs/headline"
    },
    "methodology": {
      "$ref": "#/$defs/methodology"
    },
    "top_risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskItem"
      }
    },
    "privilege_budget": {"$ref": "#/$defs/privilegeBudget"},
    "deltas": {
      "$ref": "#/$defs/deltas"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycle"
    },
    "regress_drift": {
      "$ref": "#/$defs/regress"
    },
    "proof": {
      "$ref": "#/$defs/proofReference"
    },
    "next_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checklistItem"
      }
    },
    "action_paths": {
      "type": "array",
      "items": {"$ref": "#/$defs/actionPath"}
    },
    "action_path_to_control_first": {
      "$ref": "#/$defs/actionPathToControlFirst"
    },
    "control_path_graph": {
      "$ref": "#/$defs/controlPathGraph"
    },
    "source_privacy": {
      "$ref": "#/$defs/sourcePrivacy"
    },
    "runtime_evidence": {
      "$ref": "#/$defs/runtimeEvidence"
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "title", "facts", "impact", "action", "proof"],
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "facts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "impact": {"type": "string"},
        "action": {"type": "string"},
        "proof": {"$ref": "#/$defs/proofReference"}
      }
    },
    "headline": {
      "type": "object",
      "required": ["score", "grade", "compliance_status", "compliance_percent"],
      "properties": {
        "score": {"type": "number"},
        "grade": {"type": "string"},
        "compliance_status": {"type": "string"},
        "compliance_percent": {"type": "number"}
      }
    },
    "methodology": {
      "type": "object",
      "required": [
        "wrkr_version",
        "scan_started_at",
        "scan_completed_at",
        "scan_duration_seconds",
        "repo_count",
        "file_count_processed",
        "detector_count",
        "command_set",
        "sample_definition",
        "exclusion_criteria"
      ],
      "properties": {
        "wrkr_version": {"type": "string"},
        "scan_started_at": {"type": "string"},
        "scan_completed_at": {"type": "string"},
        "scan_duration_seconds": {"type": "number"},
        "repo_count": {"type": "integer"},
        "file_count_processed": {"type": "integer"},
        "detector_count": {"type": "integer"},
        "command_set": {"type": "array", "items": {"type": "string"}},
        "sample_definition": {"type": "string"},
        "exclusion_criteria": {"type": "array", "items": {"type": "string"}}
      }
    },
    "credentialProvenance": {
      "type": "object",
      "required": ["type", "scope", "confidence", "risk_multiplier"],
      "properties": {
        "type": {"type": "string", "enum": ["static_secret", "workload_identity", "inherited_human", "oauth_delegation", "jit", "unknown"]},
        "subject": {"type": "string"},
        "scope": {"type": "string", "enum": ["repository", "workflow", "tool", "environment", "organization", "unknown"]},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "evidence_basis": {"type": "array", "items": {"type": "string"}},
        "risk_multiplier": {"type": "number"}
      },
      "additionalProperties": false
    },
    "actionPath": {
      "type": "object",
      "required": ["path_id", "org", "repo", "tool_type", "write_capable", "approval_gap", "credential_access", "attack_path_score", "risk_score", "recommended_action"],
      "properties": {
        "path_id": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "agent_id": {"type": "string"},
        "tool_type": {"type": "string"},
        "location": {"type": "string"},
        "write_capable": {"type": "boolean"},
        "approval_gap": {"type": "boolean"},
        "credential_access": {"type": "boolean"},
        "credential_provenance": {"$ref": "#/$defs/credentialProvenance"},
        "trust_depth": {"$ref": "#/$defs/trustDepth"},
        "attack_path_score": {"type": "number"},
        "risk_score": {"type": "number"},
        "recommended_action": {"type": "string"},
        "write_path_classes": {"type": "array", "items": {"type": "string"}},
        "governance_controls": {"type": "array", "items": {"type": "object"}}
      }
    },
    "actionPathToControlFirst": {
      "type": "object",
      "required": ["summary", "path"],
      "properties": {
        "summary": {
          "type": "object",
          "required": ["total_paths", "write_capable_paths", "production_target_backed_paths", "govern_first_paths"],
          "properties": {
            "total_paths": {"type": "integer"},
            "write_capable_paths": {"type": "integer"},
            "production_target_backed_paths": {"type": "integer"},
            "govern_first_paths": {"type": "integer"}
          }
        },
        "path": {"$ref": "#/$defs/actionPath"}
      }
    },
    "controlPathKindRollup": {
      "type": "object",
      "required": ["kind", "count"],
      "properties": {
        "kind": {"type": "string"},
        "count": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "controlPathGraphNode": {
      "type": "object",
      "required": ["node_id", "path_id", "kind", "org", "repo"],
      "properties": {
        "node_id": {"type": "string"},
        "path_id": {"type": "string"},
        "kind": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "label": {"type": "string"},
        "tool_type": {"type": "string"},
        "location": {"type": "string"},
        "agent_id": {"type": "string"},
        "status": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "source_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "controlPathGraphEdge": {
      "type": "object",
      "required": ["edge_id", "path_id", "kind", "from_node_id", "to_node_id"],
      "properties": {
        "edge_id": {"type": "string"},
        "path_id": {"type": "string"},
        "kind": {"type": "string"},
        "from_node_id": {"type": "string"},
        "to_node_id": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "source_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "controlPathGraph": {
      "type": "object",
      "required": ["version", "summary", "nodes", "edges"],
      "properties": {
        "version": {"type": "string", "enum": ["1"]},
        "summary": {
          "type": "object",
          "required": ["total_nodes", "total_edges", "node_kinds", "edge_kinds"],
          "properties": {
            "total_nodes": {"type": "integer"},
            "total_edges": {"type": "integer"},
            "node_kinds": {"type": "array", "items": {"$ref": "#/$defs/controlPathKindRollup"}},
            "edge_kinds": {"type": "array", "items": {"$ref": "#/$defs/controlPathKindRollup"}}
          },
          "additionalProperties": false
        },
        "nodes": {"type": "array", "items": {"$ref": "#/$defs/controlPathGraphNode"}},
        "edges": {"type": "array", "items": {"$ref": "#/$defs/controlPathGraphEdge"}}
      },
      "additionalProperties": false
    },
    "riskItem": {
      "type": "object",
      "required": [
        "rank",
        "canonical_key",
        "risk_score",
        "finding_type",
        "severity",
        "tool_type",
        "org",
        "repo",
        "location",
        "rationale",
        "remediation"
      ],
      "properties": {
        "rank": {"type": "integer"},
        "canonical_key": {"type": "string"},
        "risk_score": {"type": "number"},
        "finding_type": {"type": "string"},
        "severity": {"type": "string"},
        "tool_type": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "location": {"type": "string"},
        "rationale": {
          "type": "array",
          "items": {"type": "string"}
        },
        "remediation": {"type": "string"}
      }
    },
    "deltas": {
      "type": "object",
      "required": ["risk_score_trend", "profile_compliance_delta", "posture_score_trend_delta"],
      "properties": {
        "risk_score_trend": {"$ref": "#/$defs/deltaMetric"},
        "profile_compliance_delta": {"$ref": "#/$defs/deltaMetric"},
        "posture_score_trend_delta": {"$ref": "#/$defs/deltaMetric"}
      }
    },
    "privilegeBudget": {
      "type": "object",
      "required": ["total_tools", "write_capable_tools", "credential_access_tools", "exec_capable_tools", "production_write"],
      "properties": {
        "total_tools": {"type": "integer"},
        "write_capable_tools": {"type": "integer"},
        "credential_access_tools": {"type": "integer"},
        "exec_capable_tools": {"type": "integer"},
        "production_write": {
          "type": "object",
          "required": ["configured", "status", "count"],
          "properties": {
            "configured": {"type": "boolean"},
            "status": {"type": "string", "enum": ["configured", "not_configured", "invalid"]},
            "count": {"type": ["integer", "null"]}
          }
        }
      }
    },
    "deltaMetric": {
      "type": "object",
      "required": ["current", "previous", "delta", "has_previous"],
      "properties": {
        "current": {"type": "number"},
        "previous": {"type": "number"},
        "delta": {"type": "number"},
        "has_previous": {"type": "boolean"}
      }
    },
    "lifecycle": {
      "type": "object",
      "required": [
        "identity_count",
        "under_review_count",
        "revoked_count",
        "deprecated_count",
        "pending_action_count",
        "recent_transitions"
      ],
      "properties": {
        "identity_count": {"type": "integer"},
        "under_review_count": {"type": "integer"},
        "revoked_count": {"type": "integer"},
        "deprecated_count": {"type": "integer"},
        "pending_action_count": {"type": "integer"},
        "gaps": {"type": "array", "items": {"$ref": "#/$defs/lifecycleGap"}},
        "recent_transitions": {
          "type": "array",
          "items": {"$ref": "#/$defs/lifecycleTransition"}
        }
      }
    },
    "lifecycleGap": {
      "type": "object",
      "required": ["gap_id", "reason_code", "severity", "agent_id", "org", "present", "message"],
      "properties": {
        "gap_id": {"type": "string"},
        "reason_code": {"type": "string"},
        "severity": {"type": "string"},
        "agent_id": {"type": "string"},
        "tool_id": {"type": "string"},
        "tool_type": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "location": {"type": "string"},
        "present": {"type": "boolean"},
        "lifecycle_state": {"type": "string"},
        "approval_status": {"type": "string"},
        "owner": {"type": "string"},
        "ownership_status": {"type": "string"},
        "write_capable": {"type": "boolean"},
        "credential_access": {"type": "boolean"},
        "message": {"type": "string"},
        "evidence_basis": {"type": "array", "items": {"type": "string"}}
      }
    },
    "lifecycleTransition": {
      "type": "object",
      "required": ["agent_id", "previous_state", "new_state", "trigger", "timestamp"],
      "properties": {
        "agent_id": {"type": "string"},
        "previous_state": {"type": "string"},
        "new_state": {"type": "string"},
        "trigger": {"type": "string"},
        "timestamp": {"type": "string"}
      }
    },
    "regress": {
      "type": "object",
      "required": ["baseline_provided", "drift_detected", "reason_count", "reason_groups"],
      "properties": {
        "baseline_provided": {"type": "boolean"},
        "drift_detected": {"type": "boolean"},
        "reason_count": {"type": "integer"},
        "reason_groups": {
          "type": "array",
          "items": {"$ref": "#/$defs/reasonGroup"}
        }
      }
    },
    "reasonGroup": {
      "type": "object",
      "required": ["code", "count"],
      "properties": {
        "code": {"type": "string"},
        "count": {"type": "integer"}
      }
    },
    "proofReference": {
      "type": "object",
      "required": ["chain_path", "head_hash", "record_count", "record_type_counts", "canonical_finding_keys"],
      "properties": {
        "chain_path": {"type": "string"},
        "head_hash": {"type": "string"},
        "record_count": {"type": "integer"},
        "record_type_counts": {
          "type": "array",
          "items": {"$ref": "#/$defs/recordTypeCount"}
        },
        "canonical_finding_keys": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "recordTypeCount": {
      "type": "object",
      "required": ["record_type", "count"],
      "properties": {
        "record_type": {"type": "string"},
        "count": {"type": "integer"}
      }
    },
    "checklistItem": {
      "type": "object",
      "required": ["id", "text"],
      "properties": {
        "id": {"type": "string"},
        "text": {"type": "string"}
      }
    },
    "trustDepth": {
      "type": "object",
      "required": ["auth_strength", "delegation_model", "exposure", "policy_binding", "gateway_binding", "gateway_coverage", "trust_depth_score"],
      "properties": {
        "surface": {"type": "string", "enum": ["mcp", "a2a"]},
        "auth_strength": {"type": "string", "enum": ["none", "static_secret", "workload_identity", "inherited_human", "oauth_delegation", "jit", "unknown"]},
        "delegation_model": {"type": "string", "enum": ["none", "tool_proxy", "agent_delegate", "unknown"]},
        "exposure": {"type": "string", "enum": ["local", "private", "public", "unknown"]},
        "policy_binding": {"type": "string", "enum": ["declared", "missing"]},
        "policy_refs": {"type": "array", "items": {"type": "string"}},
        "gateway_binding": {"type": "string", "enum": ["bound", "unbound", "unknown"]},
        "gateway_coverage": {"type": "string", "enum": ["protected", "unprotected", "unknown"]},
        "sanitization_claims": {"type": "array", "items": {"type": "string"}},
        "capability_exposure": {"type": "array", "items": {"type": "string"}},
        "trust_gaps": {"type": "array", "items": {"type": "string"}},
        "trust_depth_score": {"type": "number"}
      },
      "additionalProperties": false
    },
    "runtimeEvidenceCorrelation": {
      "type": "object",
      "required": ["path_id", "status"],
      "properties": {
        "path_id": {"type": "string"},
        "agent_id": {"type": "string"},
        "tool": {"type": "string"},
        "repo": {"type": "string"},
        "status": {"type": "string"},
        "evidence_classes": {"type": "array", "items": {"type": "string"}},
        "sources": {"type": "array", "items": {"type": "string"}},
        "policy_refs": {"type": "array", "items": {"type": "string"}},
        "proof_refs": {"type": "array", "items": {"type": "string"}},
        "record_ids": {"type": "array", "items": {"type": "string"}},
        "latest_observed_at": {"type": "string"}
      }
    },
    "runtimeEvidence": {
      "type": "object",
      "required": ["total_records", "matched_records", "unmatched_records"],
      "properties": {
        "artifact_path": {"type": "string"},
        "total_records": {"type": "integer"},
        "matched_records": {"type": "integer"},
        "unmatched_records": {"type": "integer"},
        "correlations": {"type": "array", "items": {"$ref": "#/$defs/runtimeEvidenceCorrelation"}}
      }
    },
    "sourcePrivacy": {
      "type": "object",
      "required": [
        "retention_mode",
        "materialized_source_retained",
        "raw_source_in_artifacts",
        "serialized_locations",
        "cleanup_status"
      ],
      "properties": {
        "retention_mode": {
          "type": "string",
          "enum": ["ephemeral", "retain_for_resume", "retain"]
        },
        "materialized_source_retained": {"type": "boolean"},
        "raw_source_in_artifacts": {"type": "boolean"},
        "serialized_locations": {
          "type": "string",
          "enum": ["logical", "filesystem"]
        },
        "cleanup_status": {
          "type": "string",
          "enum": ["not_applicable", "pending", "removed", "retained", "failed"]
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
