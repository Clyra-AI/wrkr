{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.clyra.ai/wrkr/v1/report/report-summary.schema.json",
  "title": "Wrkr Report Summary",
  "type": "object",
  "required": [
    "summary_version",
    "generated_at",
    "template",
    "share_profile",
    "section_order",
    "sections",
    "headline",
    "methodology",
    "top_risks",
    "privilege_budget",
    "deltas",
    "lifecycle",
    "proof",
    "next_actions"
  ],
  "properties": {
    "summary_version": {
      "type": "string",
      "enum": ["v1"]
    },
    "generated_at": {
      "type": "string"
    },
    "template": {
      "type": "string",
      "enum": ["exec", "operator", "audit", "public", "ciso", "appsec", "platform", "customer-draft", "agent-action-bom", "design-partner-summary"]
    },
    "share_profile": {
      "type": "string",
      "enum": ["internal", "public", "customer-redacted", "design-partner", "external-redacted", "investor-safe"]
    },
    "share_profile_metadata": {
      "$ref": "#/$defs/shareProfileMetadata"
    },
    "section_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "headline": {
      "$ref": "#/$defs/headline"
    },
    "scan_scope": {
      "$ref": "#/$defs/scanScope"
    },
    "operational_exposure": {
      "$ref": "#/$defs/axisSummary"
    },
    "governance_readiness": {
      "$ref": "#/$defs/axisSummary"
    },
    "methodology": {
      "$ref": "#/$defs/methodology"
    },
    "top_risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskItem"
      }
    },
    "privilege_budget": {"$ref": "#/$defs/privilegeBudget"},
    "deltas": {
      "$ref": "#/$defs/deltas"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycle"
    },
    "regress_drift": {
      "$ref": "#/$defs/regress"
    },
    "proof": {
      "$ref": "#/$defs/proofReference"
    },
    "next_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checklistItem"
      }
    },
    "action_paths": {
      "type": "array",
      "items": {"$ref": "#/$defs/actionPath"}
    },
    "action_path_to_control_first": {
      "$ref": "#/$defs/actionPathToControlFirst"
    },
    "action_surface_registry": {
      "type": "array",
      "items": {"$ref": "#/$defs/actionSurfaceRegistryEntry"}
    },
    "control_path_graph": {
      "$ref": "#/$defs/controlPathGraph"
    },
    "scan_quality": {
      "$ref": "#/$defs/scanQuality"
    },
    "source_privacy": {
      "$ref": "#/$defs/sourcePrivacy"
    },
    "runtime_evidence": {
      "$ref": "#/$defs/runtimeEvidence"
    },
    "agent_action_bom": {
      "$ref": "../agent-action-bom.schema.json"
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "title", "facts", "impact", "action", "proof"],
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "facts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "impact": {"type": "string"},
        "action": {"type": "string"},
        "proof": {"$ref": "#/$defs/proofReference"}
      }
    },
    "headline": {
      "type": "object",
      "required": ["score", "grade", "compliance_status", "compliance_percent"],
      "properties": {
        "score": {"type": "number"},
        "grade": {"type": "string"},
        "compliance_status": {"type": "string"},
        "compliance_percent": {"type": "number"}
      }
    },
    "shareProfileMetadata": {
      "type": "object",
      "required": ["redaction_applied"],
      "properties": {
        "redaction_applied": {"type": "boolean"},
        "redaction_version": {"type": "string"},
        "policy_summary": {
          "type": "array",
          "items": {"type": "string"}
        },
        "selected_fields": {
          "type": "array",
          "items": {"type": "string"}
        },
        "profile_default_fields": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "scanScope": {
      "type": "object",
      "required": ["mode", "scope_label", "source_boundary", "repo_count", "target_count"],
      "properties": {
        "mode": {"type": "string"},
        "scope_label": {"type": "string"},
        "source_boundary": {"type": "string"},
        "repo_count": {"type": "integer"},
        "target_count": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "axisSummary": {
      "type": "object",
      "required": ["grade", "path_count", "driver"],
      "properties": {
        "grade": {"type": "string"},
        "path_count": {"type": "integer"},
        "driver": {"type": "string"},
        "rationale": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "methodology": {
      "type": "object",
      "required": [
        "wrkr_version",
        "scan_started_at",
        "scan_completed_at",
        "scan_duration_seconds",
        "repo_count",
        "file_count_processed",
        "detector_count",
        "command_set",
        "sample_definition",
        "exclusion_criteria"
      ],
      "properties": {
        "wrkr_version": {"type": "string"},
        "scan_started_at": {"type": "string"},
        "scan_completed_at": {"type": "string"},
        "scan_duration_seconds": {"type": "number"},
        "repo_count": {"type": "integer"},
        "file_count_processed": {"type": "integer"},
        "detector_count": {"type": "integer"},
        "command_set": {"type": "array", "items": {"type": "string"}},
        "sample_definition": {"type": "string"},
        "exclusion_criteria": {"type": "array", "items": {"type": "string"}}
      }
    },
    "credentialProvenance": {
      "type": "object",
      "required": ["type", "scope", "confidence", "risk_multiplier"],
      "properties": {
        "type": {"type": "string", "enum": ["static_secret", "workload_identity", "inherited_human", "oauth_delegation", "jit", "unknown"]},
        "subject": {"type": "string"},
        "scope": {"type": "string", "enum": ["repository", "workflow", "tool", "environment", "organization", "unknown"]},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "evidence_basis": {"type": "array", "items": {"type": "string"}},
        "credential_kind": {"type": "string", "enum": ["github_pat", "github_workflow_token", "github_app_key", "deploy_key", "cloud_admin_key", "cloud_access_key", "oidc_workload_identity", "delegated_oauth", "jit_credential", "inherited_human", "static_secret", "unknown_durable", "unknown"]},
        "access_type": {"type": "string", "enum": ["standing", "jit", "delegated", "workload", "inherited", "unknown"]},
        "standing_access": {"type": "boolean"},
        "likely_jit": {"type": "boolean"},
        "evidence_location": {"type": "string"},
        "classification_reasons": {"type": "array", "items": {"type": "string"}},
        "risk_multiplier": {"type": "number"}
      },
      "additionalProperties": false
    },
    "credentialAuthority": {
      "type": "object",
      "required": ["credential_present", "credential_referenced_by_workflow", "credential_usable_by_path", "standing_access", "likely_jit"],
      "properties": {
        "credential_present": {"type": "boolean"},
        "credential_referenced_by_workflow": {"type": "boolean"},
        "credential_usable_by_path": {"type": "boolean"},
        "credential_kind": {"type": "string", "enum": ["github_pat", "github_workflow_token", "github_app_key", "deploy_key", "cloud_admin_key", "cloud_access_key", "oidc_workload_identity", "delegated_oauth", "jit_credential", "inherited_human", "static_secret", "unknown_durable", "unknown"]},
        "access_type": {"type": "string", "enum": ["standing", "jit", "delegated", "workload", "inherited", "unknown"]},
        "standing_access": {"type": "boolean"},
        "likely_jit": {"type": "boolean"},
        "rotation_evidence_status": {"type": "string", "enum": ["present", "missing", "not_applicable", "unknown", "stale"]},
        "credential_source": {"type": "string", "enum": ["workflow_secret_ref", "workflow_builtin_token", "non_human_identity", "auth_surface", "detector_evidence", "direct_config", "unknown"]},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "actionLineage": {
      "type": "object",
      "properties": {
        "segments": {
          "type": "array",
          "items": {"$ref": "#/$defs/actionLineageSegment"}
        }
      },
      "additionalProperties": false
    },
    "actionLineageSegment": {
      "type": "object",
      "required": ["segment_id", "kind"],
      "properties": {
        "segment_id": {"type": "string"},
        "kind": {"type": "string", "enum": ["repo", "workflow", "agent", "action", "credential", "target", "owner", "approval", "proof"]},
        "label": {"type": "string"},
        "status": {"type": "string"},
        "node_ids": {"type": "array", "items": {"type": "string"}},
        "edge_ids": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "actionPath": {
      "type": "object",
      "required": ["path_id", "org", "repo", "tool_type", "write_capable", "approval_gap", "credential_access", "attack_path_score", "risk_score", "recommended_action"],
      "properties": {
        "path_id": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "agent_id": {"type": "string"},
        "tool_family_id": {"type": "string"},
        "tool_instance_id": {"type": "string"},
        "tool_type": {"type": "string"},
        "location": {"type": "string"},
        "location_range": {"$ref": "#/$defs/locationRange"},
        "purpose": {"type": "string"},
        "purpose_source": {"type": "string"},
        "purpose_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "version": {"type": "string"},
        "version_source": {"type": "string"},
        "config_fingerprint": {"type": "string"},
        "config_source": {"type": "string"},
        "write_capable": {"type": "boolean"},
        "control_resolution_state": {"type": "string", "enum": ["detected_control", "declared_control", "external_control_reference", "no_visible_control", "not_applicable", "contradictory_control"]},
        "control_resolution_reasons": {"type": "array", "items": {"type": "string"}},
        "control_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "constraint_evidence_classes": {"type": "array", "items": {"type": "string"}},
        "constraint_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "constraint_evidence_status": {"type": "string", "enum": ["matched", "stale", "conflict"]},
        "approval_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "owner_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "proof_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "runtime_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "target_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "credential_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "target_class": {"type": "string", "enum": ["production_impacting", "release_adjacent", "customer_data_adjacent", "internal_tooling", "developer_productivity", "test_demo_sandbox", "unknown"]},
        "target_class_reasons": {"type": "array", "items": {"type": "string"}},
        "target_class_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "action_path_type": {"type": "string", "enum": ["ai_assisted_workflow", "agent_framework", "automation_bot", "ci_cd_workflow", "legacy_script", "plain_source_code", "unknown_executable_path"]},
        "action_path_type_reasons": {"type": "array", "items": {"type": "string"}},
        "action_path_type_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "approval_gap": {"type": "boolean"},
        "credential_access": {"type": "boolean"},
        "credentials": {
          "type": "array",
          "items": {"$ref": "#/$defs/credentialProvenance"}
        },
        "credential_provenance": {"$ref": "#/$defs/credentialProvenance"},
        "credential_authority": {"$ref": "#/$defs/credentialAuthority"},
        "path_context": {"$ref": "#/$defs/pathContext"},
        "action_classes": {"type": "array", "items": {"type": "string"}},
        "action_reasons": {"type": "array", "items": {"type": "string"}},
        "mutable_endpoint_semantics": {
          "type": "array",
          "items": {"$ref": "#/$defs/mutableEndpointSemantic"}
        },
        "trust_depth": {"$ref": "#/$defs/trustDepth"},
        "policy_coverage_status": {"type": "string", "enum": ["none", "declared", "matched", "runtime_proven", "stale", "conflict"]},
        "policy_refs": {"type": "array", "items": {"type": "string"}},
        "policy_missing_reasons": {"type": "array", "items": {"type": "string"}},
        "policy_status_reasons": {"type": "array", "items": {"type": "string"}},
        "policy_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "policy_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "control_state": {"$ref": "#/$defs/controlState"},
        "control_state_reasons": {"type": "array", "items": {"type": "string"}},
        "risk_zone": {"$ref": "#/$defs/riskZone"},
        "risk_zone_reasons": {"type": "array", "items": {"type": "string"}},
        "review_burden": {"$ref": "#/$defs/reviewBurden"},
        "review_burden_reasons": {"type": "array", "items": {"type": "string"}},
        "confidence_lane": {"type": "string", "enum": ["confirmed_action_path", "likely_action_path", "semantic_review_candidate", "context_only"]},
        "confidence_lane_reasons": {"type": "array", "items": {"type": "string"}},
        "gait_coverage": {"$ref": "#/$defs/gaitCoverage"},
        "introduced_by": {"$ref": "#/$defs/introducedBy"},
        "inventory_risk": {"type": "string", "enum": ["production_backed", "write_capable", "credential_access", "visibility_only", "dependency_only"]},
        "control_priority": {"type": "string", "enum": ["control_first", "review_queue", "inventory_hygiene"]},
        "risk_tier": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
        "attack_path_score": {"type": "number"},
        "risk_score": {"type": "number"},
        "recommended_action": {"type": "string"},
        "attack_path_refs": {"type": "array", "items": {"type": "string"}},
        "source_finding_keys": {"type": "array", "items": {"type": "string"}},
        "standing_privilege_reasons": {"type": "array", "items": {"type": "string"}},
        "write_path_classes": {"type": "array", "items": {"type": "string"}},
        "governance_controls": {"type": "array", "items": {"type": "object"}},
        "action_lineage": {"$ref": "#/$defs/actionLineage"}
      }
    },
    "controlState": {
      "type": "string",
      "enum": ["safe_by_default", "approval_required", "block_recommended", "evidence_required", "inventory_only"]
    },
    "riskZone": {
      "type": "string",
      "enum": ["coding_help", "repo_write", "credential_bearing", "ci_cd", "iac", "release", "production_data", "external_egress"]
    },
    "reviewBurden": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "gaitCoverage": {
      "type": "object",
      "required": ["policy_decision", "approval", "jit_credential", "freeze_window", "kill_switch", "action_outcome", "proof_verification"],
      "properties": {
        "policy_decision": {"$ref": "#/$defs/gaitCoverageDetail"},
        "approval": {"$ref": "#/$defs/gaitCoverageDetail"},
        "jit_credential": {"$ref": "#/$defs/gaitCoverageDetail"},
        "freeze_window": {"$ref": "#/$defs/gaitCoverageDetail"},
        "kill_switch": {"$ref": "#/$defs/gaitCoverageDetail"},
        "action_outcome": {"$ref": "#/$defs/gaitCoverageDetail"},
        "proof_verification": {"$ref": "#/$defs/gaitCoverageDetail"}
      },
      "additionalProperties": false
    },
    "gaitCoverageDetail": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {"type": "string", "enum": ["present", "missing", "stale", "conflict", "not_applicable"]},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "mutableEndpointSemantic": {
      "type": "object",
      "required": ["semantic"],
      "properties": {
        "semantic": {"type": "string", "enum": ["read", "write", "delete", "deploy", "refund", "payment", "user_admin", "data_export", "production_mutation"]},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "surface": {"type": "string"},
        "operation": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "actionPathToControlFirst": {
      "type": "object",
      "required": ["summary", "path"],
      "properties": {
        "summary": {
          "type": "object",
          "required": ["total_paths", "write_capable_paths", "production_target_backed_paths", "govern_first_paths"],
          "properties": {
            "total_paths": {"type": "integer"},
            "write_capable_paths": {"type": "integer"},
            "credential_access_paths": {"type": "integer"},
            "standing_privilege_paths": {"type": "integer"},
            "production_target_backed_paths": {"type": "integer"},
            "control_first_paths": {"type": "integer"},
            "govern_first_paths": {"type": "integer"},
            "detected_control_paths": {"type": "integer"},
            "declared_control_paths": {"type": "integer"},
            "external_control_reference_paths": {"type": "integer"},
            "contradictory_control_paths": {"type": "integer"},
            "control_evidence_unknown_paths": {"type": "integer"},
            "approval_evidence_unknown_paths": {"type": "integer"},
            "owner_evidence_unknown_paths": {"type": "integer"},
            "proof_evidence_unknown_paths": {"type": "integer"},
            "missing_approval_paths": {"type": "integer"},
            "missing_policy_paths": {"type": "integer"},
            "missing_proof_paths": {"type": "integer"},
            "unresolved_owner_paths": {"type": "integer"},
            "high_review_burden_paths": {"type": "integer"},
            "confirmed_action_paths": {"type": "integer"},
            "likely_action_paths": {"type": "integer"},
            "semantic_review_candidate_paths": {"type": "integer"},
            "context_only_paths": {"type": "integer"},
            "empty_state_status": {"type": "string", "enum": ["eligible", "not_eligible", "coverage_reduced"]},
            "empty_state_reasons": {"type": "array", "items": {"type": "string"}}
          }
        },
        "path": {"$ref": "#/$defs/actionPath"}
      }
    },
    "actionSurfaceRegistryEntry": {
      "type": "object",
      "required": ["registry_id", "org", "repo", "tool_type", "action_path_count"],
      "properties": {
        "registry_id": {"type": "string"},
        "surface_type": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "tool_type": {"type": "string"},
        "tool_instance_id": {"type": "string"},
        "location": {"type": "string"},
        "label": {"type": "string"},
        "owner": {"type": "string"},
        "owner_source": {"type": "string"},
        "purpose": {"type": "string"},
        "purpose_source": {"type": "string"},
        "purpose_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "version": {"type": "string"},
        "version_source": {"type": "string"},
        "config_fingerprint": {"type": "string"},
        "config_source": {"type": "string"},
        "credentials": {
          "type": "array",
          "items": {"$ref": "#/$defs/credentialProvenance"}
        },
        "credential_authority": {"$ref": "#/$defs/credentialAuthority"},
        "reachable_actions": {"type": "array", "items": {"type": "string"}},
        "mutable_endpoint_semantics": {
          "type": "array",
          "items": {"$ref": "#/$defs/mutableEndpointSemantic"}
        },
        "confidence_lane": {"type": "string", "enum": ["confirmed_action_path", "likely_action_path", "semantic_review_candidate", "context_only"]},
        "proof_status": {"type": "string"},
        "remediation": {"type": "string"},
        "path_ids": {"type": "array", "items": {"type": "string"}},
        "action_path_count": {"type": "integer"},
        "graph_refs": {
          "type": "object",
          "properties": {
            "node_ids": {"type": "array", "items": {"type": "string"}},
            "edge_ids": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "scanQuality": {
      "type": "object",
      "required": ["scan_quality_version", "mode"],
      "properties": {
        "scan_quality_version": {"type": "string"},
        "mode": {"type": "string", "enum": ["quick", "governance", "deep"]},
        "compact_summary": {"$ref": "#/$defs/compactCoverageSummary"},
        "detectors": {
          "type": "array",
          "items": {"$ref": "#/$defs/detectorHealth"}
        },
        "suppressed_paths": {
          "type": "array",
          "items": {"$ref": "#/$defs/suppressedPath"}
        },
        "parse_errors": {
          "type": "array",
          "items": {"$ref": "#/$defs/parseIssue"}
        },
        "detector_errors": {
          "type": "array",
          "items": {"$ref": "#/$defs/detectorError"}
        },
        "absence_claims": {
          "type": "array",
          "items": {"$ref": "#/$defs/absenceClaim"}
        }
      },
      "additionalProperties": false
    },
    "compactCoverageSummary": {
      "type": "object",
      "required": ["coverage_confidence"],
      "properties": {
        "coverage_confidence": {"type": "string", "enum": ["complete", "reduced", "unknown"]},
        "reduced_detector_count": {"type": "integer"},
        "parse_failure_count": {"type": "integer"},
        "suppressed_generated_file_count": {"type": "integer"},
        "blocked_detector_count": {"type": "integer"},
        "unsupported_declaration_count": {"type": "integer"},
        "impact_statement": {"type": "string"}
      },
      "additionalProperties": false
    },
    "absenceClaim": {
      "type": "object",
      "required": ["surface", "status"],
      "properties": {
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "surface": {"type": "string"},
        "status": {
          "type": "string",
          "enum": [
            "not_found_with_complete_coverage",
            "not_found_with_reduced_coverage",
            "not_scanned",
            "unsupported_surface",
            "candidate_parse_failed"
          ]
        },
        "reasons": {"type": "array", "items": {"type": "string"}},
        "impact": {"type": "string"}
      },
      "additionalProperties": false
    },
    "detectorHealth": {
      "type": "object",
      "required": ["detector", "status", "attempted_files", "parsed_files"],
      "properties": {
        "org": {"type": "string"},
