{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrkr.dev/schemas/v1/agent-action-bom.schema.json",
  "title": "Wrkr Agent Action BOM",
  "type": "object",
  "required": ["bom_id", "schema_version", "generated_at", "summary"],
  "properties": {
    "bom_id": {"type": "string"},
    "schema_version": {"type": "string", "enum": ["v1"]},
    "generated_at": {"type": "string"},
    "share_profile": {"type": "string", "enum": ["internal", "public", "customer-redacted", "design-partner", "external-redacted", "investor-safe"]},
    "share_profile_metadata": {"$ref": "#/$defs/shareProfileMetadata"},
    "summary": {"$ref": "#/$defs/summary"},
    "scan_quality": {"$ref": "#/$defs/scanQuality"},
    "items": {
      "type": "array",
      "items": {"$ref": "#/$defs/item"}
    },
    "graph_refs": {"$ref": "#/$defs/graphRefs"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "proof_refs": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "summary": {
      "type": "object",
      "required": [
        "total_items",
        "control_first_items",
        "standing_privilege_items",
        "static_credential_items",
        "production_target_items",
        "missing_approval_items",
        "missing_policy_items",
        "missing_proof_items",
        "runtime_proven_items",
        "unresolved_owner_items"
      ],
      "properties": {
        "total_items": {"type": "integer"},
        "control_first_items": {"type": "integer"},
        "standing_privilege_items": {"type": "integer"},
        "static_credential_items": {"type": "integer"},
        "production_target_items": {"type": "integer"},
        "accepted_risk_items": {"type": "integer"},
        "lifecycle_queue_items": {"type": "integer"},
        "approval_evidence_unknown_items": {"type": "integer"},
        "control_evidence_unknown_items": {"type": "integer"},
        "owner_evidence_unknown_items": {"type": "integer"},
        "proof_evidence_unknown_items": {"type": "integer"},
        "missing_approval_items": {"type": "integer"},
        "missing_policy_items": {"type": "integer"},
        "missing_proof_items": {"type": "integer"},
        "runtime_proven_items": {"type": "integer"},
        "unresolved_owner_items": {"type": "integer"},
        "confirmed_action_path_items": {"type": "integer"},
        "likely_action_path_items": {"type": "integer"},
        "semantic_review_candidate_items": {"type": "integer"},
        "context_only_items": {"type": "integer"},
        "empty_state_status": {"type": "string", "enum": ["eligible", "not_eligible", "coverage_reduced"]},
        "empty_state_reasons": {"type": "array", "items": {"type": "string"}},
        "scan_scope": {"$ref": "#/$defs/scanScope"},
        "source_privacy": {"$ref": "#/$defs/sourcePrivacy"},
        "operational_exposure": {"$ref": "#/$defs/axisSummary"},
        "governance_readiness": {"$ref": "#/$defs/axisSummary"},
        "scan_coverage": {"$ref": "#/$defs/compactCoverageSummary"},
        "coverage_confidence": {"type": "string", "enum": ["complete", "reduced", "unknown"]}
      },
      "additionalProperties": false
    },
    "item": {
      "type": "object",
      "required": ["path_id", "org", "repo", "tool_type", "credential_access", "approval_gap"],
      "properties": {
        "path_id": {"type": "string"},
        "agent_id": {"type": "string"},
        "tool_family_id": {"type": "string"},
        "tool_instance_id": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "tool_type": {"type": "string"},
        "location": {"type": "string"},
        "purpose": {"type": "string"},
        "purpose_source": {"type": "string"},
        "purpose_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "version": {"type": "string"},
        "version_source": {"type": "string"},
        "config_fingerprint": {"type": "string"},
        "config_source": {"type": "string"},
        "owner": {"type": "string"},
        "owner_source": {"type": "string"},
        "ownership_status": {"type": "string"},
        "ownership_state": {"type": "string"},
        "evidence_decisions": {"type": "array", "items": {"$ref": "#/$defs/evidenceDecision"}},
        "contradictions": {"type": "array", "items": {"$ref": "#/$defs/contradiction"}},
        "governance_disposition": {"$ref": "#/$defs/governanceDisposition"},
        "lifecycle_queue": {"$ref": "#/$defs/lifecycleQueue"},
        "control_resolution_state": {"type": "string", "enum": ["detected_control", "declared_control", "external_control_reference", "no_visible_control", "not_applicable", "contradictory_control"]},
        "control_resolution_reasons": {"type": "array", "items": {"type": "string"}},
        "control_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "constraint_evidence_classes": {"type": "array", "items": {"type": "string"}},
        "constraint_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "approval_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "owner_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "proof_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "runtime_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "target_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "credential_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "target_class": {"type": "string", "enum": ["production_impacting", "release_adjacent", "customer_data_adjacent", "internal_tooling", "developer_productivity", "test_demo_sandbox", "unknown"]},
        "target_class_reasons": {"type": "array", "items": {"type": "string"}},
        "target_class_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "action_path_type": {"type": "string", "enum": ["ai_assisted_workflow", "agent_framework", "automation_bot", "ci_cd_workflow", "legacy_script", "plain_source_code", "unknown_executable_path"]},
        "action_path_type_reasons": {"type": "array", "items": {"type": "string"}},
        "action_path_type_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "credential_access": {"type": "boolean"},
        "credentials": {
          "type": "array",
          "items": {"$ref": "#/$defs/credentialProvenance"}
        },
        "credential_provenance": {"$ref": "#/$defs/credentialProvenance"},
        "credential_authority": {"$ref": "#/$defs/credentialAuthority"},
        "path_context": {"$ref": "#/$defs/pathContext"},
        "standing_privilege": {"type": "boolean"},
        "standing_privilege_reasons": {"type": "array", "items": {"type": "string"}},
        "control_state": {"$ref": "#/$defs/controlState"},
        "control_state_reasons": {"type": "array", "items": {"type": "string"}},
        "risk_zone": {"$ref": "#/$defs/riskZone"},
        "risk_zone_reasons": {"type": "array", "items": {"type": "string"}},
        "review_burden": {"$ref": "#/$defs/reviewBurden"},
        "review_burden_reasons": {"type": "array", "items": {"type": "string"}},
        "confidence_lane": {"type": "string", "enum": ["confirmed_action_path", "likely_action_path", "semantic_review_candidate", "context_only"]},
        "confidence_lane_reasons": {"type": "array", "items": {"type": "string"}},
        "action_classes": {"type": "array", "items": {"type": "string"}},
        "action_reasons": {"type": "array", "items": {"type": "string"}},
        "mutable_endpoint_semantics": {
          "type": "array",
          "items": {"$ref": "#/$defs/mutableEndpointSemantic"}
        },
        "production_write": {"type": "boolean"},
        "production_target_status": {"type": "string"},
        "matched_production_targets": {"type": "array", "items": {"type": "string"}},
        "approval_gap": {"type": "boolean"},
        "approval_gap_reasons": {"type": "array", "items": {"type": "string"}},
        "policy_status": {"type": "string", "enum": ["none", "declared", "matched", "runtime_proven", "stale", "conflict"]},
        "policy_refs": {"type": "array", "items": {"type": "string"}},
        "policy_missing_reasons": {"type": "array", "items": {"type": "string"}},
        "policy_status_reasons": {"type": "array", "items": {"type": "string"}},
        "policy_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "policy_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "proof_coverage": {"type": "string"},
        "proof_refs": {"type": "array", "items": {"type": "string"}},
        "runtime_evidence_status": {"type": "string", "enum": ["matched", "unmatched", "stale", "conflict"]},
        "runtime_evidence_absence_status": {"type": "string", "enum": ["not_collected", "not_applicable", "missing_required", "missing_for_control_claim"]},
        "runtime_evidence_classes": {"type": "array", "items": {"type": "string"}},
        "runtime_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "gait_coverage": {"$ref": "#/$defs/gaitCoverage"},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "evidence_strength": {"type": "string"},
        "inventory_risk": {"type": "string", "enum": ["production_backed", "write_capable", "credential_access", "visibility_only", "dependency_only"]},
        "control_priority": {"type": "string"},
        "risk_tier": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
        "recommended_next_action": {"type": "string"},
        "queue": {"type": "string", "enum": ["control_first", "review_queue", "accepted_risk_queue", "inventory_hygiene", "debug_only"]},
        "finding_visibility": {"type": "string", "enum": ["primary", "appendix", "debug"]},
        "remediation": {"type": "string"},
        "attack_path_refs": {"type": "array", "items": {"type": "string"}},
        "source_finding_keys": {"type": "array", "items": {"type": "string"}},
        "exclusion_reason": {"type": "string"},
        "graph_refs": {"$ref": "#/$defs/graphRefs"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "introduced_by": {"$ref": "#/$defs/introducedBy"},
        "action_lineage": {"$ref": "#/$defs/actionLineage"},
        "reachability": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachability"}
        },
        "reachable_servers": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachability"}
        },
        "reachable_tools": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachability"}
        },
        "reachable_endpoints": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachability"}
        },
        "reachable_targets": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachability"}
        },
        "reachable_apis": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachability"}
        },
        "reachable_agents": {
          "type": "array",
          "items": {"$ref": "#/$defs/reachability"}
        }
      },
      "additionalProperties": true
    },
    "evidenceCandidate": {
      "type": "object",
      "properties": {
        "field": {"type": "string"},
        "value": {"type": "string"},
        "source_type": {"type": "string"},
        "source": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "observed_at": {"type": "string"},
        "valid_until": {"type": "string"},
        "max_age": {"type": "string"},
        "issuer": {"type": "string"},
        "confidence": {"type": "string"},
        "freshness_state": {"type": "string", "enum": ["fresh", "stale", "expired", "unknown"]},
        "status": {"type": "string"},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "evidenceDecision": {
      "type": "object",
      "properties": {
        "field": {"type": "string"},
        "selected_value": {"type": "string"},
        "selected_source_type": {"type": "string"},
        "selected_source": {"type": "string"},
        "selected_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "selected_observed_at": {"type": "string"},
        "selected_valid_until": {"type": "string"},
        "selected_max_age": {"type": "string"},
        "selected_issuer": {"type": "string"},
        "selected_confidence": {"type": "string"},
        "selected_freshness_state": {"type": "string", "enum": ["fresh", "stale", "expired", "unknown"]},
        "selected_status": {"type": "string"},
        "conflict_state": {"type": "string", "enum": ["resolved", "ambiguous"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "conflict_reason_codes": {"type": "array", "items": {"type": "string"}},
        "rejected_candidates": {"type": "array", "items": {"$ref": "#/$defs/evidenceCandidate"}}
      },
      "additionalProperties": false
    },
    "contradiction": {
      "type": "object",
      "properties": {
        "class": {"type": "string"},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "impacted_target_class": {"type": "string"},
        "recommended_action": {"type": "string"}
      },
      "additionalProperties": false
    },
    "governanceDisposition": {
      "type": "object",
      "required": ["kind", "status", "reason", "scope"],
      "properties": {
        "kind": {"type": "string", "enum": ["accepted_risk", "suppression"]},
        "status": {"type": "string", "enum": ["active", "expired", "invalid"]},
        "reason": {"type": "string"},
        "scope": {"type": "string"},
        "issuer": {"type": "string"},
        "expires_at": {"type": "string"},
        "evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "visibility_behavior": {"type": "string"},
        "rescan_behavior": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "lifecycleQueue": {
      "type": "object",
      "required": ["queue_id", "gap_id", "reason_code", "severity", "recommended_action", "sla", "closure_criteria"],
      "properties": {
        "queue_id": {"type": "string"},
        "gap_id": {"type": "string"},
        "agent_id": {"type": "string"},
        "repo": {"type": "string"},
        "path": {"type": "string"},
        "reason_code": {"type": "string"},
        "severity": {"type": "string"},
        "owner": {"type": "string"},
        "owner_evidence_state": {"type": "string", "enum": ["verified", "inferred", "unknown"]},
        "credential_status": {"type": "string", "enum": ["credential_access_present", "no_credential_access"]},
        "lifecycle_status": {"type": "string"},
        "recommended_action": {"type": "string"},
        "sla": {"type": "string"},
        "closure_criteria": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "source_conflicts": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "controlState": {
      "type": "string",
      "enum": ["safe_by_default", "approval_required", "block_recommended", "evidence_required", "inventory_only"]
    },
    "riskZone": {
      "type": "string",
      "enum": ["coding_help", "repo_write", "credential_bearing", "ci_cd", "iac", "release", "production_data", "external_egress"]
    },
    "reviewBurden": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "gaitCoverage": {
      "type": "object",
      "required": ["policy_decision", "approval", "jit_credential", "freeze_window", "kill_switch", "action_outcome", "proof_verification"],
      "properties": {
        "policy_decision": {"$ref": "#/$defs/gaitCoverageDetail"},
        "approval": {"$ref": "#/$defs/gaitCoverageDetail"},
        "jit_credential": {"$ref": "#/$defs/gaitCoverageDetail"},
        "freeze_window": {"$ref": "#/$defs/gaitCoverageDetail"},
        "kill_switch": {"$ref": "#/$defs/gaitCoverageDetail"},
        "action_outcome": {"$ref": "#/$defs/gaitCoverageDetail"},
        "proof_verification": {"$ref": "#/$defs/gaitCoverageDetail"}
      },
      "additionalProperties": false
    },
    "gaitCoverageDetail": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {"type": "string", "enum": ["present", "missing", "stale", "conflict", "not_applicable"]},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "graphRefs": {
      "type": "object",
      "properties": {
        "node_ids": {"type": "array", "items": {"type": "string"}},
        "edge_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "mutableEndpointSemantic": {
      "type": "object",
      "required": ["semantic"],
      "properties": {
        "semantic": {"type": "string", "enum": ["read", "write", "delete", "deploy", "refund", "payment", "user_admin", "data_export", "production_mutation"]},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "surface": {"type": "string"},
        "operation": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "shareProfileMetadata": {
      "type": "object",
      "required": ["redaction_applied"],
      "properties": {
        "redaction_applied": {"type": "boolean"},
        "redaction_version": {"type": "string"},
        "policy_summary": {
          "type": "array",
          "items": {"type": "string"}
        },
        "selected_fields": {
          "type": "array",
          "items": {"type": "string"}
        },
        "profile_default_fields": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "scanScope": {
      "type": "object",
      "required": ["mode", "scope_label", "source_boundary", "repo_count", "target_count"],
      "properties": {
        "mode": {"type": "string"},
        "scope_label": {"type": "string"},
        "source_boundary": {"type": "string"},
        "repo_count": {"type": "integer"},
        "target_count": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "axisSummary": {
      "type": "object",
      "required": ["grade", "path_count", "driver"],
      "properties": {
        "grade": {"type": "string"},
        "path_count": {"type": "integer"},
        "driver": {"type": "string"},
        "rationale": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "sourcePrivacy": {
      "type": "object",
      "required": [
        "retention_mode",
        "materialized_source_retained",
        "raw_source_in_artifacts",
        "serialized_locations",
        "cleanup_status"
      ],
      "properties": {
        "retention_mode": {
          "type": "string",
          "enum": ["ephemeral", "retain_for_resume", "retain"]
        },
        "materialized_source_retained": {"type": "boolean"},
        "raw_source_in_artifacts": {"type": "boolean"},
        "serialized_locations": {
          "type": "string",
          "enum": ["logical", "filesystem"]
        },
        "cleanup_status": {
          "type": "string",
          "enum": ["not_applicable", "pending", "removed", "retained", "failed"]
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "scanQuality": {
      "type": "object",
      "required": ["scan_quality_version", "mode"],
      "properties": {
        "scan_quality_version": {"type": "string"},
        "mode": {"type": "string", "enum": ["quick", "governance", "deep"]},
        "compact_summary": {"$ref": "#/$defs/compactCoverageSummary"},
        "detectors": {
          "type": "array",
          "items": {"$ref": "#/$defs/detectorHealth"}
        },
        "suppressed_paths": {
          "type": "array",
          "items": {"$ref": "#/$defs/suppressedPath"}
        },
        "parse_errors": {
          "type": "array",
          "items": {"$ref": "#/$defs/parseIssue"}
        },
        "detector_errors": {
          "type": "array",
          "items": {"$ref": "#/$defs/detectorError"}
        },
        "absence_claims": {
          "type": "array",
          "items": {"$ref": "#/$defs/absenceClaim"}
        }
      },
      "additionalProperties": false
    },
    "compactCoverageSummary": {
      "type": "object",
      "required": ["coverage_confidence"],
      "properties": {
        "coverage_confidence": {"type": "string", "enum": ["complete", "reduced", "unknown"]},
        "reduced_detector_count": {"type": "integer"},
        "parse_failure_count": {"type": "integer"},
        "suppressed_generated_file_count": {"type": "integer"},
        "blocked_detector_count": {"type": "integer"},
        "unsupported_declaration_count": {"type": "integer"},
        "impact_statement": {"type": "string"}
      },
      "additionalProperties": false
    },
    "absenceClaim": {
      "type": "object",
      "required": ["surface", "status"],
      "properties": {
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "surface": {"type": "string"},
        "status": {
          "type": "string",
          "enum": [
            "not_found_with_complete_coverage",
            "not_found_with_reduced_coverage",
            "not_scanned",
            "unsupported_surface",
            "candidate_parse_failed"
          ]
        },
        "reasons": {"type": "array", "items": {"type": "string"}},
        "impact": {"type": "string"}
      },
      "additionalProperties": false
    },
    "detectorHealth": {
      "type": "object",
      "required": ["detector", "status", "attempted_files", "parsed_files"],
      "properties": {
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "detector": {"type": "string"},
        "status": {"type": "string", "enum": ["complete", "partial", "reduced", "blocked"]},
        "coverage_reasons": {"type": "array", "items": {"type": "string"}},
        "attempted_files": {"type": "integer"},
        "parsed_files": {"type": "integer"},
        "partial_parses": {"type": "integer"},
        "skipped_files": {"type": "integer"},
        "suppressed_files": {"type": "integer"},
        "parse_failures": {"type": "integer"},
        "unsupported_declarations": {"type": "integer"},
        "findings": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "suppressedPath": {
      "type": "object",
      "required": ["path", "kind", "reason"],
      "properties": {
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "path": {"type": "string"},
        "kind": {"type": "string"},
        "reason": {"type": "string"}
      },
      "additionalProperties": false
    },
    "parseIssue": {
      "type": "object",
      "required": ["path", "kind"],
      "properties": {
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "path": {"type": "string"},
        "detector": {"type": "string"},
        "kind": {"type": "string"},
        "format": {"type": "string"},
        "message": {"type": "string"},
        "reason": {"type": "string"},
        "recommended_action": {"type": "string"}
      },
      "additionalProperties": false
    },
    "detectorError": {
      "type": "object",
      "required": ["detector", "org", "repo", "code", "class", "message"],
      "properties": {
        "detector": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "code": {"type": "string"},
        "class": {"type": "string"},
        "message": {"type": "string"}
      },
      "additionalProperties": false
    },
    "reachability": {
