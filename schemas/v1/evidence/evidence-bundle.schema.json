{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Clyra-AI/wrkr/schemas/v1/evidence/evidence-bundle.schema.json",
  "title": "Wrkr Evidence Bundle Manifest",
  "type": "object",
  "required": ["status", "output_dir", "frameworks", "manifest_path", "chain_path"],
  "properties": {
    "status": {"const": "ok"},
    "output_dir": {"type": "string"},
    "frameworks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "manifest_path": {"type": "string"},
    "chain_path": {"type": "string"},
    "framework_coverage": {
      "type": "object",
      "additionalProperties": {"type": "number"}
    },
    "source_privacy": {
      "$ref": "#/definitions/sourcePrivacy"
    },
    "runtime_evidence": {
      "$ref": "#/definitions/runtimeEvidence"
    }
  },
  "definitions": {
    "sourcePrivacy": {
      "type": "object",
      "required": [
        "retention_mode",
        "materialized_source_retained",
        "raw_source_in_artifacts",
        "serialized_locations",
        "cleanup_status"
      ],
      "properties": {
        "retention_mode": {
          "type": "string",
          "enum": ["ephemeral", "retain_for_resume", "retain"]
        },
        "materialized_source_retained": {"type": "boolean"},
        "raw_source_in_artifacts": {"type": "boolean"},
        "serialized_locations": {
          "type": "string",
          "enum": ["logical", "filesystem"]
        },
        "cleanup_status": {
          "type": "string",
          "enum": ["not_applicable", "pending", "removed", "retained", "failed"]
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "runtimeEvidence": {
      "type": "object",
      "required": ["total_records", "matched_records", "unmatched_records"],
      "properties": {
        "artifact_path": {"type": "string"},
        "total_records": {"type": "integer", "minimum": 0},
        "matched_records": {"type": "integer", "minimum": 0},
        "unmatched_records": {"type": "integer", "minimum": 0},
        "correlations": {
          "type": "array",
          "items": {"$ref": "#/definitions/runtimeEvidenceCorrelation"}
        }
      },
      "additionalProperties": true
    },
    "runtimeEvidenceCorrelation": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "path_id": {"type": "string"},
        "agent_id": {"type": "string"},
        "tool": {"type": "string"},
        "repo": {"type": "string"},
        "status": {"type": "string", "enum": ["matched", "unmatched"]},
        "evidence_classes": {"type": "array", "items": {"type": "string"}},
        "sources": {"type": "array", "items": {"type": "string"}},
        "policy_refs": {"type": "array", "items": {"type": "string"}},
        "proof_refs": {"type": "array", "items": {"type": "string"}},
        "record_ids": {"type": "array", "items": {"type": "string"}},
        "latest_observed_at": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
