{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Clyra-AI/wrkr/schemas/v1/evidence/evidence-bundle.schema.json",
  "title": "Wrkr Evidence Bundle Manifest",
  "type": "object",
  "required": ["status", "output_dir", "frameworks", "manifest_path", "chain_path"],
  "properties": {
    "status": {"const": "ok"},
    "deployment_mode": {
      "$ref": "#/definitions/deploymentMode"
    },
    "output_dir": {"type": "string"},
    "frameworks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "manifest_path": {"type": "string"},
    "chain_path": {"type": "string"},
    "framework_coverage": {
      "type": "object",
      "additionalProperties": {"type": "number"}
    },
    "source_privacy": {
      "$ref": "#/definitions/sourcePrivacy"
    },
    "runtime_evidence": {
      "$ref": "#/definitions/runtimeEvidence"
    },
    "artifact_budget": {
      "$ref": "../report/report-summary.schema.json#/$defs/artifactBudget"
    },
    "appendix_available": {"type": "boolean"},
    "focused_bundle_available": {"type": "boolean"},
    "full_export_available": {"type": "boolean"},
    "suppressed_counts": {
      "$ref": "../report/report-summary.schema.json#/$defs/suppressedCounts"
    },
    "evidence_packets": {
      "$ref": "../report/report-summary.schema.json#/$defs/evidencePacketSummary"
    },
    "composition_refs": {
      "type": "array",
      "items": {"$ref": "#/definitions/compositionRef"}
    },
    "executive_rollup": {
      "$ref": "../report/report-summary.schema.json#/$defs/executiveRollup"
    },
    "governed_usage_metrics": {
      "$ref": "../report/report-summary.schema.json#/$defs/governedUsageMetrics"
    },
    "action_surface_registry": {
      "type": "array",
      "items": {
        "$ref": "../report/report-summary.schema.json#/$defs/actionSurfaceRegistryEntry"
      }
    },
    "agent_action_bom": {
      "$ref": "../agent-action-bom.schema.json"
    }
  },
  "definitions": {
    "deploymentMode": {
      "type": "string",
      "enum": ["local_only", "customer_controlled_storage", "connected_saas_metadata", "managed_platform"]
    },
    "sourcePrivacy": {
      "type": "object",
      "required": [
        "retention_mode",
        "deployment_mode",
        "materialized_source_retained",
        "raw_source_in_artifacts",
        "serialized_locations",
        "cleanup_status"
      ],
      "properties": {
        "retention_mode": {
          "type": "string",
          "enum": ["ephemeral", "retain_for_resume", "retain"]
        },
        "deployment_mode": {
          "$ref": "#/definitions/deploymentMode"
        },
        "materialized_source_retained": {"type": "boolean"},
        "raw_source_in_artifacts": {"type": "boolean"},
        "serialized_locations": {
          "type": "string",
          "enum": ["logical", "filesystem"]
        },
        "cleanup_status": {
          "type": "string",
          "enum": ["not_applicable", "pending", "removed", "retained", "failed"]
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "runtimeEvidence": {
      "type": "object",
      "required": ["total_records", "matched_records", "unmatched_records"],
      "properties": {
        "artifact_path": {"type": "string"},
        "total_records": {"type": "integer", "minimum": 0},
        "runtime_records": {"type": "integer", "minimum": 0},
        "external_control_records": {"type": "integer", "minimum": 0},
        "matched_records": {"type": "integer", "minimum": 0},
        "unmatched_records": {"type": "integer", "minimum": 0},
        "correlations": {
          "type": "array",
          "items": {"$ref": "#/definitions/runtimeEvidenceCorrelation"}
        }
      },
      "additionalProperties": true
    },
    "runtimeEvidenceCorrelation": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "path_id": {"type": "string"},
        "agent_id": {"type": "string"},
        "record_kinds": {"type": "array", "items": {"type": "string"}},
        "source_types": {"type": "array", "items": {"type": "string"}},
        "tool": {"type": "string"},
        "repo": {"type": "string"},
        "service": {"type": "string"},
        "workflow": {"type": "string"},
        "environment": {"type": "string"},
        "path": {"type": "string"},
        "location": {"type": "string"},
        "target": {"type": "string"},
        "status": {"type": "string", "enum": ["matched", "unmatched", "stale", "conflict"]},
        "evidence_classes": {"type": "array", "items": {"type": "string"}},
        "action_classes": {"type": "array", "items": {"type": "string"}},
        "sources": {"type": "array", "items": {"type": "string"}},
        "policy_refs": {"type": "array", "items": {"type": "string"}},
        "proof_refs": {"type": "array", "items": {"type": "string"}},
        "graph_node_refs": {"type": "array", "items": {"type": "string"}},
        "graph_edge_refs": {"type": "array", "items": {"type": "string"}},
        "record_ids": {"type": "array", "items": {"type": "string"}},
        "required_checks": {"type": "array", "items": {"type": "string"}},
        "owners": {"type": "array", "items": {"type": "string"}},
        "unmatched_reasons": {"type": "array", "items": {"type": "string"}},
        "latest_observed_at": {"type": "string"},
        "containment_status": {"type": "string", "enum": ["contained", "partially_contained", "unresolved", "out_of_scope"]},
        "containment_scope_refs": {"type": "array", "items": {"type": "string"}},
        "acknowledged_boundary_refs": {"type": "array", "items": {"type": "string"}},
        "unresolved_boundary_refs": {"type": "array", "items": {"type": "string"}},
        "out_of_scope_boundary_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "compositionRef": {
      "type": "object",
      "required": ["composition_id"],
      "properties": {
        "composition_id": {"type": "string"},
        "resolution_key": {"type": "string"},
        "pattern_id": {"type": "string"},
        "path_ids": {"type": "array", "items": {"type": "string"}},
        "workflow_chain_refs": {"type": "array", "items": {"type": "string"}},
        "proposed_action_contract_refs": {"type": "array", "items": {"type": "string"}},
        "recommended_control": {"type": "string"},
        "evidence_state": {"type": "string"},
        "policy_coverage_status": {"type": "string"},
        "gait_coverage_summary": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "proposed_action_contract_id": {"type": "string"},
        "contract_family_id": {"type": "string"},
        "contract_revision": {"type": "integer", "minimum": 1},
        "contract_content_digest": {"type": "string"},
        "supersedes_ref": {"type": "string"},
        "action_contract_artifact_refs": {"type": "array", "items": {"type": "string"}},
        "lifecycle_observation_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
