{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrkr.dev/schemas/v1/risk/risk-report.schema.json",
  "title": "Wrkr Risk Report",
  "type": "object",
  "required": ["generated_at", "top_findings", "ranked_findings", "repo_risk"],
  "properties": {
    "generated_at": {"type": "string", "format": "date-time"},
    "top_findings": {"type": "array"},
    "ranked_findings": {"type": "array"},
    "repo_risk": {"type": "array"},
    "attack_paths": {"type": "array"},
    "top_attack_paths": {"type": "array"},
    "action_paths": {
      "type": "array",
      "items": {"$ref": "#/$defs/actionPath"}
    },
    "action_path_to_control_first": {
      "type": "object",
      "properties": {
        "summary": {"type": "object"},
        "path": {"$ref": "#/$defs/actionPath"}
      },
      "additionalProperties": true
    },
    "workflow_chains": {
      "$ref": "#/$defs/workflowChainArtifact"
    },
    "control_path_graph": {
      "$ref": "../control-path-graph.schema.json"
    }
  },
  "$defs": {
    "actionPath": {
      "type": "object",
      "required": ["path_id", "org", "repo", "tool_type", "write_capable", "production_write", "approval_gap", "credential_access", "attack_path_score", "risk_score", "recommended_action"],
      "properties": {
        "path_id": {"type": "string"},
        "org": {"type": "string"},
        "repo": {"type": "string"},
        "agent_id": {"type": "string"},
        "tool_family_id": {"type": "string"},
        "tool_instance_id": {"type": "string"},
        "tool_type": {"type": "string"},
        "location": {"type": "string"},
        "location_range": {"$ref": "#/$defs/locationRange"},
        "purpose": {"type": "string"},
        "purpose_source": {"type": "string"},
        "purpose_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "version": {"type": "string"},
        "version_source": {"type": "string"},
        "config_fingerprint": {"type": "string"},
        "config_source": {"type": "string"},
        "write_capable": {"type": "boolean"},
        "write_path_classes": {"type": "array", "items": {"type": "string"}},
        "control_resolution_state": {"type": "string", "enum": ["detected_control", "declared_control", "external_control_reference", "no_visible_control", "not_applicable", "contradictory_control"]},
        "control_resolution_reasons": {"type": "array", "items": {"type": "string"}},
        "control_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "approval_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "owner_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "proof_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "runtime_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "target_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "credential_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "target_class": {"type": "string", "enum": ["production_impacting", "release_adjacent", "customer_data_adjacent", "internal_tooling", "developer_productivity", "test_demo_sandbox", "unknown"]},
        "target_class_reasons": {"type": "array", "items": {"type": "string"}},
        "target_class_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "evidence_decisions": {"type": "array", "items": {"$ref": "#/$defs/evidenceDecision"}},
        "contradictions": {"type": "array", "items": {"$ref": "#/$defs/contradiction"}},
        "action_path_type": {"type": "string", "enum": ["ai_assisted_workflow", "agent_framework", "automation_bot", "ci_cd_workflow", "legacy_script", "plain_source_code", "unknown_executable_path"]},
        "action_path_type_reasons": {"type": "array", "items": {"type": "string"}},
        "action_path_type_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "action_classes": {"type": "array", "items": {"type": "string"}},
        "action_reasons": {"type": "array", "items": {"type": "string"}},
        "mutable_endpoint_semantics": {
          "type": "array",
          "items": {"$ref": "#/$defs/mutableEndpointSemantic"}
        },
        "pull_request_write": {"type": "boolean"},
        "merge_execute": {"type": "boolean"},
        "deploy_write": {"type": "boolean"},
        "production_write": {"type": "boolean"},
        "approval_gap": {"type": "boolean"},
        "security_visibility_status": {"type": "string"},
        "credential_access": {"type": "boolean"},
        "credentials": {
          "type": "array",
          "items": {"$ref": "#/$defs/credentialProvenance"}
        },
        "credential_provenance": {"$ref": "#/$defs/credentialProvenance"},
        "credential_authority": {"$ref": "#/$defs/credentialAuthority"},
        "authority_bindings": {
          "type": "array",
          "items": {"$ref": "#/$defs/authorityBinding"}
        },
        "path_context": {"$ref": "#/$defs/pathContext"},
        "deployment_status": {"type": "string"},
        "workflow_trigger_class": {"type": "string"},
        "execution_identity": {"type": "string"},
        "execution_identity_type": {"type": "string"},
        "execution_identity_source": {"type": "string"},
        "execution_identity_status": {"type": "string"},
        "execution_identity_rationale": {"type": "string"},
        "business_state_surface": {"type": "string"},
        "shared_execution_identity": {"type": "boolean"},
        "standing_privilege": {"type": "boolean"},
        "standing_privilege_reasons": {"type": "array", "items": {"type": "string"}},
        "control_state": {"$ref": "#/$defs/controlState"},
        "control_state_reasons": {"type": "array", "items": {"type": "string"}},
        "risk_zone": {"$ref": "#/$defs/riskZone"},
        "risk_zone_reasons": {"type": "array", "items": {"type": "string"}},
        "review_burden": {"$ref": "#/$defs/reviewBurden"},
        "review_burden_reasons": {"type": "array", "items": {"type": "string"}},
        "confidence_lane": {"type": "string", "enum": ["confirmed_action_path", "likely_action_path", "semantic_review_candidate", "context_only"]},
        "confidence_lane_reasons": {"type": "array", "items": {"type": "string"}},
        "autonomy_tier": {"$ref": "#/$defs/autonomyTier"},
        "autonomy_tier_reasons": {"type": "array", "items": {"type": "string"}},
        "autonomy_tier_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "delegation_readiness_state": {"$ref": "#/$defs/delegationReadinessState"},
        "delegation_readiness_reasons": {"type": "array", "items": {"type": "string"}},
        "recommended_control": {"$ref": "#/$defs/recommendedControl"},
        "recommended_control_reasons": {"type": "array", "items": {"type": "string"}},
        "risk_classification_validation_reasons": {"type": "array", "items": {"type": "string"}},
        "risk_classification_validation_refs": {"type": "array", "items": {"type": "string"}},
        "recommended_action_contract": {"$ref": "#/$defs/recommendedActionContract"},
        "today_path": {"$ref": "#/$defs/governedPathView"},
        "recommended_governed_path": {"$ref": "#/$defs/governedPathView"},
        "agentic_delivery_system_change": {"$ref": "#/$defs/agenticDeliverySystemChange"},
        "runtime_context_evidence_state": {"type": "string", "enum": ["verified", "unknown", "contradictory"]},
        "runtime_provider": {"type": "string"},
        "runtime_host": {"type": "string"},
        "runtime_kind": {"type": "string"},
        "model_provider": {"type": "string"},
        "model_version": {"type": "string"},
        "execution_environment": {"type": "string"},
        "state_retention_evidence_state": {"type": "string", "enum": ["verified", "unknown", "contradictory"]},
        "state_retention_status": {"type": "string"},
        "retained_state_types": {"type": "array", "items": {"type": "string"}},
        "state_location_refs": {"type": "array", "items": {"type": "string"}},
        "state_digest_refs": {"type": "array", "items": {"type": "string"}},
        "agent_identity": {"type": "object"},
        "decision_precedent": {"type": "object"},
        "delivery_control_context": {"type": "object"},
        "high_stakes_presets": {
          "type": "array",
          "items": {"$ref": "#/$defs/highStakesPreset"}
        },
        "production_context": {"$ref": "#/$defs/productionContext"},
        "policy_coverage_status": {"type": "string", "enum": ["none", "declared", "matched", "runtime_proven", "stale", "conflict"]},
        "policy_refs": {"type": "array", "items": {"type": "string"}},
        "policy_missing_reasons": {"type": "array", "items": {"type": "string"}},
        "policy_status_reasons": {"type": "array", "items": {"type": "string"}},
        "policy_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "policy_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "evidence_packet_status": {"type": "string", "enum": ["matched", "unmatched", "stale", "conflict"]},
        "evidence_packet_result": {"type": "string", "enum": ["complete", "partial", "failed"]},
        "evidence_packet_missing_evidence_state": {"type": "string", "enum": ["complete", "partial", "missing"]},
        "evidence_packet_refs": {"type": "array", "items": {"type": "string"}},
        "gait_coverage": {"$ref": "#/$defs/gaitCoverage"},
        "introduced_by": {"$ref": "#/$defs/introducedBy"},
        "inventory_risk": {"type": "string", "enum": ["production_backed", "write_capable", "credential_access", "visibility_only", "dependency_only"]},
        "control_priority": {"type": "string", "enum": ["control_first", "review_queue", "inventory_hygiene"]},
        "risk_tier": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
        "attack_path_score": {"type": "number"},
        "risk_score": {"type": "number"},
        "recommended_action": {"type": "string"},
        "attack_path_refs": {"type": "array", "items": {"type": "string"}},
        "source_finding_keys": {"type": "array", "items": {"type": "string"}},
        "workflow_chain_refs": {"type": "array", "items": {"type": "string"}},
        "decision_trace_refs": {"type": "array", "items": {"type": "string"}},
        "matched_production_targets": {"type": "array", "items": {"type": "string"}},
        "governance_controls": {"type": "array"},
        "closure_requirements": {"type": "array", "items": {"$ref": "#/$defs/closureRequirement"}},
        "evidence_completeness": {"$ref": "#/$defs/evidenceCompleteness"},
        "action_lineage": {"$ref": "#/$defs/actionLineage"}
      },
      "additionalProperties": true
    },
    "agenticDeliverySystemChange": {
      "type": "object",
      "properties": {
        "change_id": {"type": "string"},
        "surface_type": {"type": "string", "enum": ["instruction", "skillpack", "agent_rule", "mcp_config", "tool_config"]},
        "changed_artifact": {"type": "string"},
        "authority_impact": {"type": "string", "enum": ["production_mutation", "release_or_deploy", "credential_authority", "review_bypass", "write_scope", "review_surface", "none"]},
        "authority_impact_reasons": {"type": "array", "items": {"type": "string"}},
        "reachable_tools": {"type": "array", "items": {"type": "string"}},
        "reachable_targets": {"type": "array", "items": {"type": "string"}},
        "credential_reach": {"type": "string"},
        "review_state": {"type": "string", "enum": ["review_protected", "approval_missing", "review_partial", "review_bypass_risk", "review_unknown"]},
        "review_state_reasons": {"type": "array", "items": {"type": "string"}},
        "recommended_control": {"$ref": "#/$defs/recommendedControl"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "high_impact": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "closureRequirement": {
      "type": "object",
      "required": ["id", "severity", "requirement_type", "required_evidence", "guidance"],
      "properties": {
        "id": {"type": "string"},
        "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
        "requirement_type": {"type": "string"},
        "current_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "required_evidence": {"type": "string"},
        "acceptable_source_classes": {"type": "array", "items": {"type": "string"}},
        "freshness_requirement": {"type": "string"},
        "examples": {"type": "array", "items": {"type": "string"}},
        "closure_refs": {"type": "array", "items": {"type": "string"}},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "guidance": {"type": "string"}
      },
      "additionalProperties": false
    },
    "evidenceCompletenessAxisScore": {
      "type": "object",
      "required": ["axis", "score"],
      "properties": {
        "axis": {"type": "string", "enum": ["discovery", "authority", "blast_radius", "control", "runtime_evidence", "proof"]},
        "score": {"type": "integer"},
        "reasons": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "evidenceCompleteness": {
      "type": "object",
      "required": ["total_score", "label", "axis_scores"],
      "properties": {
        "total_score": {"type": "integer"},
        "label": {"type": "string", "enum": ["strong_evidence", "partial_evidence", "insufficient_evidence"]},
        "axis_scores": {"type": "array", "items": {"$ref": "#/$defs/evidenceCompletenessAxisScore"}},
        "evidence_gaps": {"type": "array", "items": {"type": "string"}},
        "unsupported_surfaces": {"type": "array", "items": {"type": "string"}},
        "freshness_penalties": {"type": "array", "items": {"type": "string"}},
        "contradiction_penalties": {"type": "array", "items": {"type": "string"}},
        "reasons": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "evidenceCandidate": {
      "type": "object",
      "properties": {
        "field": {"type": "string"},
        "value": {"type": "string"},
        "source_type": {"type": "string"},
        "source": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "observed_at": {"type": "string"},
        "valid_until": {"type": "string"},
        "max_age": {"type": "string"},
        "issuer": {"type": "string"},
        "confidence": {"type": "string"},
        "freshness_state": {"type": "string", "enum": ["fresh", "stale", "expired", "unknown"]},
        "status": {"type": "string"},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "evidenceDecision": {
      "type": "object",
      "properties": {
        "field": {"type": "string"},
        "selected_value": {"type": "string"},
        "selected_source_type": {"type": "string"},
        "selected_source": {"type": "string"},
        "selected_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "selected_observed_at": {"type": "string"},
        "selected_valid_until": {"type": "string"},
        "selected_max_age": {"type": "string"},
        "selected_issuer": {"type": "string"},
        "selected_confidence": {"type": "string"},
        "selected_freshness_state": {"type": "string", "enum": ["fresh", "stale", "expired", "unknown"]},
        "selected_status": {"type": "string"},
        "conflict_state": {"type": "string", "enum": ["resolved", "ambiguous"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "conflict_reason_codes": {"type": "array", "items": {"type": "string"}},
        "rejected_candidates": {"type": "array", "items": {"$ref": "#/$defs/evidenceCandidate"}}
      },
      "additionalProperties": false
    },
    "contradiction": {
      "type": "object",
      "properties": {
        "class": {"type": "string"},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "impacted_target_class": {"type": "string"},
        "recommended_action": {"type": "string"}
      },
      "additionalProperties": false
    },
    "controlState": {
      "type": "string",
      "enum": ["safe_by_default", "approval_required", "block_recommended", "evidence_required", "inventory_only"]
    },
    "riskZone": {
      "type": "string",
      "enum": ["coding_help", "repo_write", "credential_bearing", "ci_cd", "iac", "release", "production_data", "external_egress"]
    },
    "reviewBurden": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "autonomyTier": {
      "type": "string",
      "enum": ["tier_0_safe_metadata", "tier_1_low_risk_internal", "tier_2_app_code_owner_review", "tier_3_sensitive_code_or_infra", "tier_4_prod_privileged_or_customer_impacting"]
    },
    "delegationReadinessState": {
      "type": "string",
      "enum": ["safe_to_delegate", "review_required", "approval_required", "proof_required", "ready_for_control", "blocked", "blocked_by_contradiction"]
    },
    "recommendedControl": {
      "type": "string",
      "enum": ["allow", "owner_review", "security_review", "approval_required", "jit_credential_required", "proof_required", "block_standing_credential", "block"]
    },
    "actionContractReadinessState": {
      "type": "string",
      "enum": ["draft", "needs_owner", "needs_approval_evidence", "ready_for_report_only", "ready_for_control", "blocked_by_contradiction"]
    },
    "recommendedActionContract": {
      "type": "object",
      "properties": {
        "path_summary": {"type": "string"},
        "allowed_action": {"type": "string"},
        "required_authority": {"type": "string"},
        "required_review": {"type": "string"},
        "required_approval": {"type": "string"},
        "required_proof": {"type": "string"},
        "allowed_autonomy_tier": {"$ref": "#/$defs/autonomyTier"},
        "validation_step": {"type": "string"},
        "validation_requirements": {"type": "array", "items": {"type": "string"}},
        "default_posture": {"type": "string"},
        "delegation_readiness_state": {"$ref": "#/$defs/delegationReadinessState"},
        "approval_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "owner_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "proof_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "outcome_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "contract_readiness_state": {"$ref": "#/$defs/actionContractReadinessState"},
        "report_only": {"type": "boolean"},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "governedPathView": {
      "type": "object",
      "properties": {
        "label": {"type": "string", "enum": ["today_path", "recommended_governed_path"]},
        "summary": {"type": "string"},
        "autonomy_tier": {"$ref": "#/$defs/autonomyTier"},
        "delegation_readiness_state": {"$ref": "#/$defs/delegationReadinessState"},
        "recommended_control": {"$ref": "#/$defs/recommendedControl"},
        "credential_mode": {"type": "string"},
        "approval_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "proof_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "outcome_evidence_state": {"type": "string", "enum": ["verified", "declared", "inferred", "unknown", "contradictory"]},
        "path_type": {"type": "string"},
        "target_class": {"type": "string"},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "gaitCoverage": {
      "type": "object",
      "required": ["policy_decision", "approval", "jit_credential", "freeze_window", "kill_switch", "action_outcome", "proof_verification"],
      "properties": {
        "policy_decision": {"$ref": "#/$defs/gaitCoverageDetail"},
        "approval": {"$ref": "#/$defs/gaitCoverageDetail"},
        "jit_credential": {"$ref": "#/$defs/gaitCoverageDetail"},
        "freeze_window": {"$ref": "#/$defs/gaitCoverageDetail"},
        "kill_switch": {"$ref": "#/$defs/gaitCoverageDetail"},
        "action_outcome": {"$ref": "#/$defs/gaitCoverageDetail"},
        "proof_verification": {"$ref": "#/$defs/gaitCoverageDetail"}
      },
      "additionalProperties": false
    },
    "gaitCoverageDetail": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {"type": "string", "enum": ["present", "missing", "stale", "conflict", "not_applicable"]},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "credentialProvenance": {
      "type": "object",
      "required": ["type", "scope", "confidence", "risk_multiplier"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["static_secret", "workload_identity", "inherited_human", "oauth_delegation", "jit", "unknown"]
        },
        "subject": {"type": "string"},
        "scope": {
          "type": "string",
          "enum": ["repository", "workflow", "tool", "environment", "organization", "unknown"]
        },
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "target_system": {"type": "string"},
        "likely_scope": {"type": "string"},
        "scope_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "evidence_basis": {"type": "array", "items": {"type": "string"}},
        "credential_kind": {"type": "string", "enum": ["github_pat", "github_workflow_token", "github_app_key", "deploy_key", "cloud_admin_key", "cloud_access_key", "oidc_workload_identity", "delegated_oauth", "jit_credential", "inherited_human", "static_secret", "unknown_durable", "unknown"]},
        "access_type": {"type": "string", "enum": ["standing", "jit", "delegated", "workload", "inherited", "unknown"]},
        "standing_access": {"type": "boolean"},
        "likely_jit": {"type": "boolean"},
        "evidence_location": {"type": "string"},
        "classification_reasons": {"type": "array", "items": {"type": "string"}},
        "risk_multiplier": {"type": "number"}
      },
      "additionalProperties": true
    },
    "credentialAuthority": {
      "type": "object",
      "required": ["credential_present", "credential_referenced_by_workflow", "credential_usable_by_path", "standing_access", "likely_jit"],
      "properties": {
        "credential_present": {"type": "boolean"},
        "credential_referenced_by_workflow": {"type": "boolean"},
        "credential_usable_by_path": {"type": "boolean"},
        "credential_kind": {"type": "string", "enum": ["github_pat", "github_workflow_token", "github_app_key", "deploy_key", "cloud_admin_key", "cloud_access_key", "oidc_workload_identity", "delegated_oauth", "jit_credential", "inherited_human", "static_secret", "unknown_durable", "unknown"]},
        "access_type": {"type": "string", "enum": ["standing", "jit", "delegated", "workload", "inherited", "unknown"]},
        "standing_access": {"type": "boolean"},
        "likely_jit": {"type": "boolean"},
        "target_system": {"type": "string"},
        "likely_scope": {"type": "string"},
        "scope_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "rotation_evidence_status": {"type": "string", "enum": ["present", "missing", "not_applicable", "unknown", "stale"]},
